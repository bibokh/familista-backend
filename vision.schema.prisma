// Familista — Vision Intelligence Engine
// Additive Prisma fragment. Merge into the main schema.prisma AFTER the
// ai-engine fragment. No required edits to existing models — VideoAsset and
// downstream rows reference subjects via plain String IDs so the audit trail
// outlives the underlying Player / Match rows.
//
// Run: npx prisma migrate dev --name vision_engine

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum VideoSource {
  UPLOAD
  STREAM_URL
  HLS
  RTMP
  EXTERNAL_PROVIDER
}

enum VideoFormat {
  MP4
  MKV
  MOV
  HLS
  RTMP
  WEBM
}

enum IngestStage {
  UPLOADED
  DEMUXED
  INFERRED
  TRACKED
  EVENTS_DETECTED
  ANALYTICS_COMPUTED
  FUSED
  COMPLETED
  FAILED
}

enum IngestStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum VisionEventType {
  PASS
  SHOT
  SAVE
  TACKLE
  INTERCEPTION
  CLEARANCE
  DRIBBLE
  FOUL
  OFFSIDE
  YELLOW_CARD
  RED_CARD
  GOAL
  THROW_IN
  CORNER
  FREE_KICK
  PENALTY
  SUBSTITUTION
  POSSESSION_CHANGE
  PRESSING_TRIGGER
  COUNTER_ATTACK
  SET_PIECE
  HEADER
  CROSS
  SPRINT
  ACCELERATION
  DECELERATION
  OTHER
}

enum TeamSide {
  HOME
  AWAY
  UNKNOWN
}

enum AnalyticsKind {
  HEATMAP
  PASSING_NETWORK
  FORMATION_SNAPSHOT
  PRESSING_EVENT
  POSSESSION_BLOCK
  ZONE_OCCUPATION
  SHAPE_COMPACTNESS
  DEFENSIVE_LINE
  TRANSITION_SPEED
  BUILD_UP_PATTERN
  SPRINT_PROFILE
  TECHNICAL_EXECUTION
  REPETITION_QUALITY
  OFF_BALL_MOVEMENT
}

enum ClipPurpose {
  HIGHLIGHT
  COACH_REVIEW
  PLAYER_FEEDBACK
  OPPONENT_SCOUTING
  TALENT_DETECTION
  TACTICAL_REFERENCE
  INCIDENT
}

enum ClipStatus {
  REQUESTED
  RENDERING
  READY
  FAILED
  EXPIRED
  CANCELLED
}

enum LiveStreamStatus {
  IDLE
  LIVE
  PAUSED
  ENDED
}

enum FusionVerdict {
  CONSISTENT
  MINOR_DRIFT
  MAJOR_DRIFT
  CONTRADICTION
  VISION_ONLY
  SENSOR_ONLY
  INSUFFICIENT_DATA
}

enum ScoutingKind {
  OPPONENT_BRIEF
  TALENT_SCAN
  RECRUITMENT_BRIEF
  ACADEMY_PROSPECT
  MATCH_REPORT
}

enum VisionAuditCategory {
  INGEST
  INFERENCE
  TRACKING
  EVENTS
  ANALYTICS
  FUSION
  CLIP
  SCOUTING
  REALTIME
  OVERRIDE
  ACCESS
  OTHER
}

enum VisionAuditResult {
  SUCCESS
  FAILURE
  REJECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// Source video + ingest pipeline
// ─────────────────────────────────────────────────────────────────────────────

model VideoAsset {
  id                String       @id @default(uuid())
  source            VideoSource
  format            VideoFormat
  url               String
  durationMs        Int?
  fps               Float?
  width             Int?
  height            Int?
  fileBytes         Int?
  checksum          String?

  clubId            String?
  matchId           String?
  trainingSessionId String?

  title             String?
  description       String?      @db.Text
  metadata          Json?

  createdBy         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  ingestJobs        VideoIngestJob[]
  analyses          VisionAnalysisRun[]
  clips             Clip[]

  @@index([clubId])
  @@index([matchId])
  @@index([trainingSessionId])
  @@index([source])
}

model VideoIngestJob {
  id                 String         @id @default(uuid())
  videoAssetId       String
  videoAsset         VideoAsset     @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  stage              IngestStage    @default(UPLOADED)
  status             IngestStatus   @default(QUEUED)
  progress           Float          @default(0)

  inferenceProvider  String?
  externalJobId      String?

  startedAt          DateTime?
  finishedAt         DateTime?
  error              String?        @db.Text
  notes              String?        @db.Text
  metadata           Json?

  createdBy          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([videoAssetId])
  @@index([stage])
  @@index([status])
  @@index([externalJobId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Analysis runs + outputs
// ─────────────────────────────────────────────────────────────────────────────

model VisionAnalysisRun {
  id                String         @id @default(uuid())
  videoAssetId      String
  videoAsset        VideoAsset     @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  matchId           String?
  trainingSessionId String?
  clubId            String?

  modelProvider     String
  modelVersion      String
  status            IngestStatus   @default(QUEUED)
  confidence        Float?

  startedAt         DateTime?
  finishedAt        DateTime?
  durationMs        Int?

  framesProcessed   Int            @default(0)
  framesTotal       Int?

  warningsCount     Int            @default(0)
  errorsCount       Int            @default(0)

  metadata          Json?
  createdBy         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  playerTracks      PlayerTrack[]
  ballTracks        BallTrack[]
  events            MatchEvent[]
  analyticsResults  AnalyticsResult[]

  @@index([videoAssetId])
  @@index([matchId])
  @@index([clubId])
  @@index([status])
}

model PlayerTrack {
  id              String              @id @default(uuid())
  analysisId      String
  analysis        VisionAnalysisRun   @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  playerId        String?
  jerseyNumber    Int?
  teamSide        TeamSide            @default(UNKNOWN)

  startMs         Int
  endMs           Int
  avgX            Float
  avgY            Float

  topSpeedKmh     Float?
  avgSpeedKmh     Float?
  totalDistanceM  Float?
  sprintCount     Int?
  accelerations   Int?
  decelerations   Int?

  pathUrl         String?
  confidence      Float               @default(1.0)

  createdAt       DateTime            @default(now())

  @@index([analysisId, playerId])
  @@index([analysisId, teamSide])
  @@index([startMs])
}

model BallTrack {
  id              String              @id @default(uuid())
  analysisId      String
  analysis        VisionAnalysisRun   @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  startMs         Int
  endMs           Int
  pathUrl         String?
  avgSpeedKmh     Float?
  topSpeedKmh     Float?
  inPlayMs        Int?
  confidence      Float               @default(1.0)

  createdAt       DateTime            @default(now())

  @@index([analysisId])
}

model MatchEvent {
  id                String              @id @default(uuid())
  analysisId        String
  analysis          VisionAnalysisRun   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  matchId           String?

  type              VisionEventType
  occurredAtMs      Int
  frame             Int?
  durationMs        Int?

  primaryPlayerId   String?
  secondaryPlayerId String?
  teamSide          TeamSide            @default(UNKNOWN)

  pitchX            Float?
  pitchY            Float?

  confidence        Float               @default(1.0)
  payload           Json?

  overrideReason    String?
  overriddenBy      String?
  overriddenAt      DateTime?

  createdAt         DateTime            @default(now())

  @@index([analysisId, type])
  @@index([matchId, occurredAtMs])
  @@index([primaryPlayerId])
  @@index([secondaryPlayerId])
}

model AnalyticsResult {
  id              String              @id @default(uuid())
  analysisId      String
  analysis        VisionAnalysisRun   @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  matchId         String?
  trainingSessionId String?
  playerId        String?
  teamSide        TeamSide            @default(UNKNOWN)

  kind            AnalyticsKind
  windowStartMs   Int?
  windowEndMs     Int?

  payload         Json
  confidence      Float               @default(1.0)
  notes           String?             @db.Text

  createdAt       DateTime            @default(now())

  @@index([analysisId, kind])
  @@index([matchId, kind])
  @@index([playerId])
  @@index([trainingSessionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sensor + vision fusion
// ─────────────────────────────────────────────────────────────────────────────

model FusedPlayerSample {
  id                  String          @id @default(uuid())
  matchId             String?
  trainingSessionId   String?
  playerId            String

  windowStartMs       Int
  windowEndMs         Int

  visionDistanceM     Float?
  visionTopSpeedKmh   Float?
  visionAvgSpeedKmh   Float?
  visionSprintCount   Int?

  sensorDistanceM     Float?
  sensorTopSpeedKmh   Float?
  sensorPlayerLoad    Float?
  sensorHeartRateAvg  Int?
  sensorRiskScore     Float?

  fusedDistanceM      Float?
  fusedTopSpeedKmh    Float?
  fusedSprintCount    Int?

  verdict             FusionVerdict   @default(INSUFFICIENT_DATA)
  agreementScore      Float?
  conflictReasons     String[]        @default([])

  createdAt           DateTime        @default(now())

  @@index([matchId, playerId])
  @@index([trainingSessionId, playerId])
  @@index([playerId, windowStartMs])
}

// ─────────────────────────────────────────────────────────────────────────────
// Clips + scouting + real-time
// ─────────────────────────────────────────────────────────────────────────────

model Clip {
  id                  String         @id @default(uuid())
  videoAssetId        String
  videoAsset          VideoAsset     @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  matchId             String?
  trainingSessionId   String?
  playerId            String?
  sourceEventId       String?

  purpose             ClipPurpose
  status              ClipStatus     @default(REQUESTED)
  startMs             Int
  endMs               Int

  renderProvider      String?
  externalRenderId    String?
  url                 String?
  thumbnailUrl        String?
  durationMs          Int?
  bytes               Int?

  title               String?
  description         String?        @db.Text
  tags                String[]       @default([])

  requestedBy         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([videoAssetId])
  @@index([matchId])
  @@index([playerId])
  @@index([purpose])
  @@index([status])
}

model LiveMatchStream {
  id              String             @id @default(uuid())
  matchId         String             @unique
  status          LiveStreamStatus   @default(IDLE)
  streamUrl       String?
  ingestJobId     String?

  startedAt       DateTime?
  endedAt         DateTime?
  lastEventAt     DateTime?
  metadata        Json?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  liveEvents      LiveEvent[]

  @@index([status])
}

model LiveEvent {
  id              String             @id @default(uuid())
  streamId        String
  stream          LiveMatchStream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  matchId         String

  type            VisionEventType
  occurredAtMs    Int
  primaryPlayerId String?
  secondaryPlayerId String?
  teamSide        TeamSide           @default(UNKNOWN)
  pitchX          Float?
  pitchY          Float?

  payload         Json?
  confidence      Float              @default(1.0)

  createdAt       DateTime           @default(now())

  @@index([streamId, occurredAtMs])
  @@index([matchId])
  @@index([type])
}

model ScoutingReport {
  id                       String         @id @default(uuid())
  kind                     ScoutingKind

  matchId                  String?
  opponentName             String?
  targetPlayerId           String?
  targetClubId             String?

  title                    String
  summary                  String         @db.Text
  payload                  Json

  confidence               Float          @default(0.7)

  generatedFromAnalysisId  String?
  generatedBy              String?

  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([matchId])
  @@index([targetPlayerId])
  @@index([kind])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────────────────────

model VisionAudit {
  id              String                 @id @default(uuid())
  analysisId      String?
  videoAssetId    String?
  matchId         String?
  userId          String?

  action          String
  category        VisionAuditCategory
  resourceType    String?
  resourceId      String?

  metadata        Json?
  ipAddress       String?
  userAgent       String?

  result          VisionAuditResult      @default(SUCCESS)
  message         String?                @db.Text

  createdAt       DateTime               @default(now())

  @@index([analysisId])
  @@index([matchId])
  @@index([action])
  @@index([category])
  @@index([createdAt])
}
