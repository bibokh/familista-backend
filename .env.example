# ============================================================
# FAMILISTA BACKEND — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database (PostgreSQL via Supabase / Neon / Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/familista?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-also-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ACADEMY=price_...

# CORS
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
