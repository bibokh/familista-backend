"document.body.style.background=\"#0d1117\"; document.body.style.margin=\"0\"; document.body.style.padding=\"24px\"; var st=document.createElement(\"style\"); st.textContent=\"/* Squad page — ultra-premium full-bleed cards */\\n.sq-prem-cards{\\n  display: grid;\\n  grid-template-columns: repeat(3, 1fr);\\n  gap: 20px;\\n  padding: 0 32px 48px;\\n  max-width: 1400px;\\n}\\n.sq-prem-card{\\n  position: relative;\\n  border-radius: 20px;\\n  overflow: hidden;\\n  min-height: 480px;\\n  cursor: pointer;\\n  user-select: none;\\n  border: 1px solid rgba(255,255,255,.07);\\n  box-shadow: 0 8px 40px rgba(0,0,0,.55);\\n  transition: transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s ease, border-color .35s ease;\\n  display: flex;\\n  flex-direction: column;\\n}\\n.sq-prem-card:hover{ transform: translateY(-12px) scale(1.015); }\\n.sq-prem-card--lineup:hover{ box-shadow: 0 36px 90px rgba(245,158,11,.32), 0 0 0 1px rgba(245,158,11,.4); border-color: rgba(245,158,11,.4); }\\n.sq-prem-card--formation:hover{ box-shadow: 0 36px 90px rgba(139,92,246,.32), 0 0 0 1px rgba(139,92,246,.4); border-color: rgba(139,92,246,.4); }\\n.sq-prem-card--tactics:hover{ box-shadow: 0 36px 90px rgba(249,115,22,.32), 0 0 0 1px rgba(249,115,22,.4); border-color: rgba(249,115,22,.4); }\\n.sq-prem-illus{\\n  position: absolute;\\n  inset: 0;\\n  overflow: hidden;\\n}\\n.sq-prem-illus svg{ width: 100%; height: 100%; display: block; }\\n.sq-prem-gradient{\\n  position: absolute;\\n  inset: 0;\\n  background: linear-gradient(to bottom, transparent 28%, rgba(5,8,20,.82) 56%, rgba(5,8,20,.97) 80%, #050814 100%);\\n  z-index: 1;\\n}\\n.sq-prem-body{\\n  position: relative;\\n  z-index: 2;\\n  margin-top: auto;\\n  padding: 22px 24px 26px;\\n}\\n.sq-prem-badge{\\n  display: inline-block;\\n  font-size: 10px;\\n  font-weight: 700;\\n  letter-spacing: .08em;\\n  text-transform: uppercase;\\n  padding: 4px 10px;\\n  border-radius: 100px;\\n  margin-bottom: 14px;\\n}\\n.sq-prem-card--lineup .sq-prem-badge{ background: rgba(245,158,11,.12); color: #fbbf24; border: 1px solid rgba(245,158,11,.28); }\\n.sq-prem-card--formation .sq-prem-badge{ background: rgba(139,92,246,.12); color: #c4b5fd; border: 1px solid rgba(139,92,246,.28); }\\n.sq-prem-card--tactics .sq-prem-badge{ background: rgba(249,115,22,.12); color: #fb923c; border: 1px solid rgba(249,115,22,.28); }\\n.sq-prem-title{\\n  font-size: 28px;\\n  font-weight: 800;\\n  color: #f8fafc;\\n  margin: 0 0 8px;\\n  letter-spacing: -.6px;\\n  line-height: 1.1;\\n}\\n.sq-prem-desc{\\n  font-size: 13.5px;\\n  color: #94a3b8;\\n  margin: 0 0 20px;\\n  line-height: 1.55;\\n}\\n.sq-prem-cta{\\n  display: flex;\\n  align-items: center;\\n  justify-content: space-between;\\n}\\n.sq-prem-open{\\n  font-size: 13px;\\n  font-weight: 600;\\n  color: rgba(241,245,249,.6);\\n  letter-spacing: -.1px;\\n}\\n.sq-prem-arrow{\\n  width: 38px;\\n  height: 38px;\\n  border-radius: 50%;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  border: 1px solid rgba(255,255,255,.16);\\n  background: rgba(255,255,255,.08);\\n  color: #f1f5f9;\\n  transition: all .2s;\\n  flex-shrink: 0;\\n}\\n.sq-prem-card:hover .sq-prem-arrow{\\n  background: rgba(255,255,255,.16);\\n  transform: translateX(4px);\\n}\"; document.head.appendChild(st);function _sqSubHtml(){return \"\";} function renderSquadHTML() {\n  // Lineup: stadium-lit pitch top-down, 4-3-3, jersey-numbered players with glow halos\n  var iLu = '<svg viewBox=\"0 0 360 480\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"xMidYMid slice\">'\n    + '<defs>'\n    + '<radialGradient id=\"l3-lt\" cx=\"0%\" cy=\"0%\" r=\"80%\"><stop offset=\"0%\" stop-color=\"rgba(255,248,200,.22)\"/><stop offset=\"100%\" stop-color=\"transparent\"/></radialGradient>'\n    + '<radialGradient id=\"l3-rt\" cx=\"100%\" cy=\"0%\" r=\"80%\"><stop offset=\"0%\" stop-color=\"rgba(255,248,200,.22)\"/><stop offset=\"100%\" stop-color=\"transparent\"/></radialGradient>'\n 