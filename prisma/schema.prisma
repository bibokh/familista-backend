// ─────────────────────────────────────────────────────────────────────────
// Phase F — Device PCB Infrastructure + Big Data Foundation
// ─────────────────────────────────────────────────────────────────────────
// Strict rules:
//  - All additive. NO FK back-relations on Club/Team/Match → existing rows
//    cannot be touched by `prisma migrate deploy`.
//  - Indexes only on hot read paths (tenant prefix + sort key).

enum DeviceProvisionStatus {
  REGISTERED
  PROVISIONED
  ACTIVE
  RETIRED
  REVOKED
}

/// Device — per-PCB registry. ONE row per physical board (FAMILISTA_WEARABLE_V1,
/// TURF_NODE, AI_CAM, SMART_BALL). Stores the long-lived HMAC secret that
/// signs sessionKey rotations. The board ships with this secret burned into
/// its eFuse + the matching row created via /api/v1/devices/register.
model Device {
  id               String                @id @default(uuid())
  clubId           String
  teamId           String?
  /// Stable serial baked into the PCB at manufacture.
  serial           String                @unique
  model            String // FAMILISTA_WEARABLE_V1 | …
  hwRevision       String? // PCB rev: R1A, R2B, …
  hmacSecret       String // long-lived HMAC root key (b64)
  /// Last-known eFuse fingerprint reported by the device. If it changes
  /// we revoke the device — likely tampering or board swap.
  efuseFingerprint String?
  status           DeviceProvisionStatus @default(REGISTERED)
  registeredAt     DateTime              @default(now())
  activatedAt      DateTime?
  retiredAt        DateTime?
  revokedAt        DateTime?
  notes            String?
  metadata         Json?

  @@index([clubId])
  @@index([clubId, status])
  @@index([model])
}

/// DeviceFirmware — OTA channel pin. One row per (model, channel). Devices
/// poll GET /devices/:id/firmware to discover the version they should run.
/// We never push — pull-only avoids hostile mid-match flashes.
model DeviceFirmware {
  id          String   @id @default(uuid())
  model       String // FAMILISTA_WEARABLE_V1 | …
  channel     String   @default("stable") // stable | beta | dev
  version     String // semver: 1.4.0
  /// SHA-256 of the firmware blob (the device verifies after download).
  sha256      String
  /// CDN URL or signed S3 link the device fetches.
  downloadUrl String
  /// Minimum-allowed hwRevision; anything older is told NOT to upgrade.
  minHwRev    String?
  notes       String?  @db.Text
  publishedAt DateTime @default(now())
  publishedBy String?
  isActive    Boolean  @default(true)

  @@unique([model, channel, version])
  @@index([model, channel, isActive])
}

/// DeviceCalibration — per-device, per-sensor calibration row. Append-only
/// (versioned) so we can replay historical packets against the calibration
/// they were captured with.
model DeviceCalibration {
  id         String   @id @default(uuid())
  deviceId   String
  sensorKind String // GPS | IMU | ECG | HEART_RATE | …
  /// Calibration version — monotonically increasing per (deviceId, sensorKind).
  version    Int      @default(1)
  /// Calibration coefficients (e.g. accelerometer bias/scale, GPS offset).
  payload    Json
  /// Operator who performed/uploaded the calibration.
  appliedBy  String?
  appliedAt  DateTime @default(now())
  isActive   Boolean  @default(true)

  @@index([deviceId, sensorKind, version])
  @@index([deviceId, isActive])
}

/// EventOutbox — deterministic event-source log. Every state-changing
/// publish() goes here BEFORE it fans out (in-proc / Redis / Kafka).
///   - `seq` is monotonic per matchId via a transactional bump
///   - `idempotencyKey` is unique → safe to retry publishers
///   - Once big-data adapters consume, they set `publishedAt`
///
/// This is the durability anchor for "deterministic replay": even if a
/// downstream consumer is offline for hours, the full ordered timeline
/// can be replayed from this table.
model EventOutbox {
  id             String    @id @default(uuid())
  clubId         String?
  matchId        String?
  seq            BigInt    @default(0)
  kind           String    @default("")
  /// External idempotency key (caller-supplied or hash of body). Lets
  /// at-least-once producers dedupe without coordination.
  idempotencyKey String?   @unique @default(uuid())
  payload        Json
  /// Source service name — useful for replay debugging.
  source         String?
  // Phase Q additions
  topic          String?
  retryCount     Int       @default(0)
  processedAt    DateTime?
  failedAt       DateTime?
  errorLog       String?   @db.Text
  createdAt      DateTime  @default(now())
  publishedAt    DateTime?
  adapters       String?

  @@index([matchId, seq])
  @@index([clubId, createdAt])
  @@index([publishedAt])
  @@index([topic, processedAt])
}

/// MatchEventSequence — internal counter table backing EventOutbox.seq.
/// One row per matchId; updated inside the same transaction as the outbox
/// insert, so seq is strictly monotonic and gap-free per match.
model MatchEventSequence {
  matchId String @id
  next    BigInt @default(0)
}

