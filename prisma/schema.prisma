// ─────────────────────────────────────────────────────────────────────────
// Phase I — Zero-Trust + Blockchain-Inspired Audit Integrity
// ─────────────────────────────────────────────────────────────────────────
// All additive. No FK back-relations on existing models.
//
// Design rules:
//  - SecurityAuditEvent is the tamper-resistant chain. Per-club ledger.
//    SHA-256 of (previousHash + actorId + clubId + action + entityType +
//    entityId + payloadHash + timestamp). Modifying any row invalidates
//    every subsequent currentHash.
//  - SecurityChainHead holds the last hash + next position per clubId, so
//    appends are O(1) without scanning the chain.
//  - LoginAttempt stores SHA-256(email) — we never persist the raw email.

enum SecurityEventKind {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_LOCKED
  TENANT_MISMATCH
  RATE_LIMITED
  SUSPICIOUS_PAYLOAD
  DEVICE_REJECTED
  DEVICE_REPLAY
  DEVICE_TS_SKEW
  PROMPT_INJECTION_SUSPECT
  UNAUTHORIZED_AI_ATTEMPT
  AUDIT_CHAIN_VERIFIED
  AUDIT_CHAIN_BROKEN
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  APPROVAL_EXPIRED
  CUSTOM
}

enum SecuritySeverity {
  INFO
  WARN
  CRITICAL
}

enum AIApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  EXECUTED
}

enum AIApprovalKind {
  DELETE_DATA
  CHANGE_TACTICS_LIVE
  MASS_MESSAGE
  APPROVE_TRANSFER
  MEDICAL_RECOMMENDATION
  PAYMENT_ACTION
  OTHER
}

/// SecurityAuditEvent — tamper-resistant blockchain-inspired audit log.
/// One chain per clubId. Append-only.
model SecurityAuditEvent {
  id            String   @id @default(uuid())
  clubId        String
  chainPosition BigInt
  actorId       String?
  teamId        String?
  action        String
  entityType    String?
  entityId      String?
  /// SHA-256 hex of canonical-stringified payload.
  payloadHash   String
  /// Hash of the previous chain row; "GENESIS" for position 0.
  previousHash  String
  /// SHA-256(previousHash + actorId + clubId + action + entityType +
  ///          entityId + payloadHash + timestamp).
  currentHash   String
  /// Captured at append time.
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@unique([clubId, chainPosition])
  @@index([clubId, createdAt])
  @@index([currentHash])
}

/// SecurityChainHead — per-club counter + lastHash, bumped atomically with
/// every SecurityAuditEvent insert. Makes appends O(1).
model SecurityChainHead {
  clubId       String   @id
  nextPosition BigInt   @default(0)
  lastHash     String   @default("GENESIS")
  updatedAt    DateTime @updatedAt
}

/// SecurityEvent — general-purpose security log. NOT chained — those are
/// SecurityAuditEvent rows. SecurityEvent is the "things noticed" feed:
/// failed logins, replay attempts, rate-limit hits, prompt-injection suspects.
model SecurityEvent {
  id        String            @id @default(uuid())
  clubId    String?
  actorId   String?
  kind      SecurityEventKind
  severity  SecuritySeverity  @default(INFO)
  ipAddress String?
  userAgent String?
  payload   Json?
  createdAt DateTime          @default(now())

  @@index([clubId, createdAt])
  @@index([kind, createdAt])
  @@index([actorId, createdAt])
}

/// LoginAttempt — failed/successful login records. Email is hashed
/// (SHA-256) so we can rate-limit without storing PII.
model LoginAttempt {
  id        String   @id @default(uuid())
  emailHash String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([emailHash, createdAt])
  @@index([ipAddress, createdAt])
}

/// AIApprovalRequest — high-risk AI actions awaiting human approval.
/// Worker parks AIAgentJob until status=APPROVED.
model AIApprovalRequest {
  id             String           @id @default(uuid())
  clubId         String
  requesterId    String
  agent          AIAgent
  kind           AIApprovalKind
  /// Reference to the AIAgentJob (if any) this request gates.
  jobId          String?
  payload        Json
  status         AIApprovalStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  @@index([clubId, status])
  @@index([status, expiresAt])
  @@index([jobId])
}

/// DeviceSecurityEvent — device-side security signals (replay rejected,
/// HMAC failure, clock skew). Separate from SecurityEvent so device
/// volume doesn't drown human-facing security signals.
model DeviceSecurityEvent {
  id              String            @id @default(uuid())
  clubId          String?
  deviceSessionId String?
  cameraId        String?
  kind            SecurityEventKind
  severity        SecuritySeverity  @default(WARN)
  payload         Json?
  createdAt       DateTime          @default(now())

  @@index([clubId, createdAt])
  @@index([deviceSessionId, createdAt])
  @@index([cameraId, createdAt])
}

