  evaluatorId   String?
  payload       Json
  score         Float    @default(0)
  modelVersion  String   @default("n1")
  createdAt     DateTime @default(now())

  @@index([clubId, createdAt])
  @@index([discoveryId])
}

// ── Autonomous market intelligence ──────────────────────────────────────

/// MarketTransferPrediction — global market prediction (extends Phase M
