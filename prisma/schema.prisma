// ─────────────────────────────────────────────────────────────────────────
// Phase N — Global Sports Knowledge Graph + Universal Identity
// ─────────────────────────────────────────────────────────────────────────
// All additive. No FK back-relations on existing models.

enum KnowledgeNodeType {
  PLAYER
  CLUB
  COACH
  SCOUT
  AGENT
  TOURNAMENT
  STADIUM
  COMPETITION
  COUNTRY
  ACADEMY
}

enum KnowledgeEdgeType {
  PLAYS_FOR
  COACHES
  REPRESENTS
  HOSTS
  IN_COMPETITION
  BELONGS_TO
  DEVELOPS
  NATIVE_OF
  SCOUTED_BY
  SIGNED_WITH
  CUSTOM
}

enum DiscoveryStatus {
  PROSPECT
  EVALUATING
  CONFIRMED
  RECOMMENDED
  REJECTED
  ARCHIVED
}

enum ReasoningKind {
  RECRUITMENT
  TACTICAL
  MEDICAL
  ECONOMIC
  DEVELOPMENT
  CUSTOM
}

// ── Global knowledge graph ──────────────────────────────────────────────

/// GlobalKnowledgeNode — polymorphic node. clubId=null means a global /
/// platform-wide node (e.g. a FIFA tournament). Tenant nodes carry clubId.
model GlobalKnowledgeNode {
  id          String            @id @default(uuid())
  clubId      String?
  nodeKind    KnowledgeNodeType
  /// External identifier (FIFA player id, transfermarkt id, etc.).
  externalRef String?
  label       String
  payload     Json
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clubId, nodeKind])
  @@index([nodeKind, isActive])
  @@index([externalRef])
}

/// GlobalKnowledgeEdge — typed relation between two nodes.
model GlobalKnowledgeEdge {
  id         String            @id @default(uuid())
  clubId     String?
  fromNodeId String
  toNodeId   String
  edgeKind   KnowledgeEdgeType
  weight     Float             @default(1.0)
  metadata   Json?
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())

  @@unique([fromNodeId, toNodeId, edgeKind])
  @@index([clubId, edgeKind])
  @@index([fromNodeId])
  @@index([toNodeId])
}

// ── Universal athlete identity ──────────────────────────────────────────

/// UniversalAthleteId — privacy-preserving athlete fingerprint.
/// idHash = SHA-256(firstName_lower | lastName_lower | dateOfBirth_ISO | sport)
/// Never stores raw PII; lets multiple clubs reconcile the same athlete.
model UniversalAthleteId {
  id        String    @id @default(uuid())
  idHash    String    @unique
  sport     SportKind @default(FOOTBALL)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([sport])
}

/// AthleteIdentityLink — per-club Player ↔ universal id mapping.
model AthleteIdentityLink {
  id         String   @id @default(uuid())
  athleteId  String // UniversalAthleteId.id
  playerId   String // Phase B Player.id (string ref)
  clubId     String
  confidence Float    @default(1.0)
  linkedById String?
  linkedAt   DateTime @default(now())

  @@unique([athleteId, playerId])
  @@index([playerId])
  @@index([clubId])
}

/// AthletePerformanceHistory — longitudinal performance summary.
model AthletePerformanceHistory {
  id         String   @id @default(uuid())
  athleteId  String
  season     String
  payload    Json
  capturedAt DateTime @default(now())

  @@index([athleteId, season])
}

/// AthleteMedicalHistory — k-anonymised medical timeline.
/// PII fields hashed; never stored in plain.
model AthleteMedicalHistory {
  id          String   @id @default(uuid())
  athleteId   String
  /// "INJURY" | "SURGERY" | "RECOVERY_MILESTONE" | "ASSESSMENT".
  recordKind  String
  payloadHash String // sha256 of plain payload (audit anchor only)
  payload     Json // k-anonymised body
  capturedAt  DateTime @default(now())

  @@index([athleteId, recordKind])
}

/// AthleteTransferHistory — append-only transfer chain.
model AthleteTransferHistory {
  id          String   @id @default(uuid())
  athleteId   String
  fromClubRef String?
  toClubRef   String?
  feeCents    BigInt?
  currency    String?  @default("EUR")
  occurredAt  DateTime
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([athleteId, occurredAt])
}

/// TalentEvolutionGraph — per-athlete development trajectory snapshot.
model TalentEvolutionGraph {
  id           String   @id @default(uuid())
  athleteId    String
  snapshot     Json
  modelVersion String   @default("n1")
  capturedAt   DateTime @default(now())

  @@index([athleteId, capturedAt])
}

// ── Global scouting intelligence ────────────────────────────────────────

/// WorldwideScoutingNode — a scouting hub (per region or per agency).
model WorldwideScoutingNode {
  id           String   @id @default(uuid())
  /// null = platform-wide federated scouting node.
  clubId       String?
  label        String
  regionCode   String? // EU | MEA | NORAM | …
  countryCodes Json? // ISO codes covered
  specialities Json?
  isActive     Boolean  @default(true)
  publishedAt  DateTime @default(now())

  @@index([regionCode, isActive])
  @@index([clubId, isActive])
}

/// TalentDiscoveryEvent — append-only pipeline row per discovered prospect.
model TalentDiscoveryEvent {
  id             String          @id @default(uuid())
  clubId         String?
  scoutingNodeId String?
  athleteIdHash  String? // optional link to UniversalAthleteId.idHash
  externalRef    String?
  prospectName   String
  position       String?
  age            Int?
  region         String?
  status         DiscoveryStatus @default(PROSPECT)
  payload        Json
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([clubId, status])
  @@index([scoutingNodeId])
  @@index([athleteIdHash])
}

/// GlobalRecommendationRanking — cross-club recommendation rankings.
/// Each row is HMAC-signed (Phase N security extension).
model GlobalRecommendationRanking {
  id            String   @id @default(uuid())
  clubId        String
  discoveryId   String?
  athleteIdHash String?
  position      String?
  score         Float // 0..1
  components    Json
  modelVersion  String   @default("n1")
  /// HMAC-SHA256(jwt.secret | "rec-rank" | clubId, canonical-stringified-payload)
  signatureB64  String?
  createdAt     DateTime @default(now())

  @@index([clubId, position, createdAt])
  @@index([discoveryId])
}

/// ConfidenceScore — versioned confidence per source/observation.
model ConfidenceScore {
  id           String   @id @default(uuid())
  clubId       String?
  sourceKind   String // "SCOUT" | "AI_AGENT" | "DATA_PROVIDER"
  sourceRef    String
  score        Float // 0..1
  components   Json?
  modelVersion String   @default("n1")
  createdAt    DateTime @default(now())

  @@index([clubId, sourceKind])
  @@index([sourceRef])
}

/// ScoutingEvaluation — replay-safe evaluation entry.
model ScoutingEvaluation {
