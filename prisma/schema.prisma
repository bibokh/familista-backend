// Familista — Executive OS · Integration Layer
// Additive Prisma fragment. Merge into the main schema.prisma AFTER all
// previous engine fragments. This layer DOES NOT duplicate operational data:
// every WorkflowStep references the existing engines via plain string
// (engine, action) tuples, and reads composite views by calling the existing
// services — never by mirroring their tables.
//
// Run: npx prisma migrate dev --name executive_integration

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum ExecutiveRole {
  CEO
  CFO
  COO
  CHAIR
  BOARD_MEMBER
  INVESTOR_LEAD
  COUNSEL
  STRATEGIC_ADVISOR
}

enum ExecutiveWorkflowKind {
  SPONSOR_ONBOARDING
  ACQUISITION
  TERRITORY_EXPANSION
  CAPITAL_DEPLOYMENT
  RISK_INTERVENTION
  PARTNERSHIP
  PLATFORM_LAUNCH
  STRATEGIC_INITIATIVE
  GOVERNANCE_ACTION
  CUSTOM
}

enum ExecutiveWorkflowStatus {
  DRAFT
  IN_REVIEW
  AWAITING_APPROVAL
  APPROVED
  IN_EXECUTION
  COMPLETED
  REJECTED
  CANCELLED
  STALLED
}

enum ExecutivePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ExecutiveStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
  BLOCKED
  REQUIRES_HUMAN
}

enum AttestationDecision {
  APPROVE
  REJECT
  ABSTAIN
}

enum BoardResolutionStatus {
  DRAFT
  CIRCULATING
  VOTING
  PASSED
  FAILED
  WITHDRAWN
}

enum BoardVoteDecision {
  FOR
  AGAINST
  ABSTAIN
}

enum SponsorTier {
  PRINCIPAL
  PLATINUM
  GOLD
  SILVER
  BRONZE
  COMMUNITY
}

enum SponsorPipelineStage {
  PROSPECT
  QUALIFIED
  PROPOSAL_SENT
  IN_NEGOTIATION
  CONTRACT_SIGNED
  ACTIVE
  RENEWAL
  CHURNED
  REJECTED
}

enum RiskCategory {
  FINANCIAL
  OPERATIONAL
  LEGAL
  REPUTATIONAL
  STRATEGIC
  TECHNICAL
  REGULATORY
}

enum RiskSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskAlertStatus {
  OPEN
  ACKNOWLEDGED
  MITIGATING
  RESOLVED
  WAIVED
  ESCALATED
}

enum ForecastScope {
  PLATFORM
  FRANCHISE_UNIT
  CLUB
  INVESTMENT_ENTITY
}

enum ForecastScenario {
  BASE
  OPTIMISTIC
  PESSIMISTIC
  STRESS
}

enum ExecutiveAuditCategory {
  WORKFLOW
  ATTESTATION
  BOARD
  SPONSOR
  FORECAST
  RISK
  ACCESS
  AGGREGATE
  OTHER
}

enum ExecutiveAuditResult {
  SUCCESS
  FAILURE
  REJECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// Executive RBAC — strategic roles, parallel to PlatformAdmin (operator roles)
// ─────────────────────────────────────────────────────────────────────────────

model ExecutiveAssignment {
  id         String        @id @default(uuid())
  userId     String        @unique
  role       ExecutiveRole
  voteWeight Float         @default(1.0)
  isActive   Boolean       @default(true)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  assignedBy String?
  notes      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attestations WorkflowAttestation[]
  boardVotes   BoardVote[]

  @@index([role])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// Workflow orchestration — multi-step, cross-engine, attestation-gated
// ─────────────────────────────────────────────────────────────────────────────

model ExecutiveWorkflow {
  id           String                @id @default(uuid())
  kind         ExecutiveWorkflowKind
  templateSlug String?
  title        String
  description  String?               @db.Text

  status   ExecutiveWorkflowStatus @default(DRAFT)
  priority ExecutivePriority       @default(NORMAL)

  // Soft cross-engine references
  clubId               String?
  franchiseUnitId      String?
  investorId           String?
  entityId             String?
  sponsorOpportunityId String?
  matchId              String?

  // Linked AI decisions that justify this workflow (soft refs)
  decisionIds String[] @default([])

  // Required attestation roles, computed from template at creation
  requiredAttestations ExecutiveRole[] @default([])

  payload Json
  outcome Json?

  initiatedBy String
  ownedBy     String?

  dueByAt         DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelledReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps        WorkflowStep[]
  attestations WorkflowAttestation[]
  resolutions  BoardResolution[]
  riskAlerts   RiskAlert[]

  @@index([kind])
  @@index([status])
  @@index([priority])
  @@index([clubId])
  @@index([franchiseUnitId])
  @@index([investorId])
  @@index([entityId])
  @@index([dueByAt])
}

model WorkflowStep {
  id         String            @id @default(uuid())
  workflowId String
  workflow   ExecutiveWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  order       Int
  name        String
  description String? @db.Text

  // (engine, action) tuple resolved by the step executor
  engine String
  action String
  params Json

  status ExecutiveStepStatus @default(PENDING)

  startedAt   DateTime?
  completedAt DateTime?
  result      Json?
  error       String?   @db.Text

  startedBy   String?
  completedBy String?

  blockedReason String? @db.Text
  attemptCount  Int     @default(0)
  maxAttempts   Int     @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workflowId, order])
  @@index([status])
}

model WorkflowAttestation {
  id         String            @id @default(uuid())
  workflowId String
  workflow   ExecutiveWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  attesterUserId       String
  attesterAssignmentId String?
  assignment           ExecutiveAssignment? @relation(fields: [attesterAssignmentId], references: [id], onDelete: SetNull)

  role     ExecutiveRole
  decision AttestationDecision

  notes        String? @db.Text
  signatureRef String?

  attestedAt DateTime @default(now())

  @@unique([workflowId, attesterUserId])
  @@index([workflowId])
  @@index([role])
}

// ─────────────────────────────────────────────────────────────────────────────
// Board resolutions + voting
// ─────────────────────────────────────────────────────────────────────────────

model BoardResolution {
  id         String             @id @default(uuid())
  workflowId String?
  workflow   ExecutiveWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  title          String
  resolutionText String                @db.Text
  status         BoardResolutionStatus @default(DRAFT)

  quorumRequired  Int   @default(3)
  passingMajority Float @default(0.5)

  votesFor     Int   @default(0)
  votesAgainst Int   @default(0)
  votesAbstain Int   @default(0)
  totalWeight  Float @default(0)

  circulationOpenedAt DateTime?
  votingOpenedAt      DateTime?
  votingClosesAt      DateTime?
  decidedAt           DateTime?
  effectiveAt         DateTime?
  withdrawnAt         DateTime?
  withdrawnReason     String?   @db.Text

  initiatedBy String

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes BoardVote[]

  @@index([status])
  @@index([votingClosesAt])
}

model BoardVote {
  id           String          @id @default(uuid())
  resolutionId String
  resolution   BoardResolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)

  voterUserId  String
  assignmentId String?
  assignment   ExecutiveAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  role     ExecutiveRole
  decision BoardVoteDecision
  weight   Float             @default(1.0)

  rationale    String? @db.Text
  signatureRef String?

  votedAt DateTime @default(now())

  @@unique([resolutionId, voterUserId])
  @@index([resolutionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sponsor pipeline
// ─────────────────────────────────────────────────────────────────────────────

model SponsorOpportunity {
  id    String               @id @default(uuid())
  name  String
  tier  SponsorTier
  stage SponsorPipelineStage @default(PROSPECT)

  clubId          String?
  franchiseUnitId String?
  workflowId      String?

  contactName  String?
  contactEmail String?
  contactPhone String?
  websiteUrl   String?
  industry     String?
  countryCode  String?

  proposedValue   Float?
  contractedValue Float?
  currency        String @default("EUR")

  termMonths Int?
  startsAt   DateTime?
  endsAt     DateTime?

  agreementUrl      String?
  agreementChecksum String?

  ownedBy  String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events SponsorPipelineEvent[]

  @@index([stage])
  @@index([tier])
  @@index([clubId])
  @@index([franchiseUnitId])
  @@index([ownedBy])
}

model SponsorPipelineEvent {
  id            String             @id @default(uuid())
  opportunityId String
  opportunity   SponsorOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  fromStage SponsorPipelineStage
  toStage   SponsorPipelineStage

  notes     String? @db.Text
  changedBy String?

  createdAt DateTime @default(now())

  @@index([opportunityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Revenue forecasting
// ─────────────────────────────────────────────────────────────────────────────

model RevenueForecast {
  id      String        @id @default(uuid())
  scope   ForecastScope
  scopeId String?

  periodKey     String
  periodStartAt DateTime
  periodEndAt   DateTime

  scenario ForecastScenario @default(BASE)

  totalRevenue  Float
  totalExpenses Float?
  netCashFlow   Float?
  currency      String @default("EUR")

  confidence   Float  @default(0.6)
  modelVersion String @default("1.0.0")
  assumptions  Json
  breakdown    Json

  generatedBy String?
  generatedAt DateTime @default(now())

  @@unique([scope, scopeId, periodKey, scenario, modelVersion])
  @@index([scope, scopeId])
  @@index([periodKey])
  @@index([scenario])
}

// ─────────────────────────────────────────────────────────────────────────────
// Risk alerts — composite signals from every engine
// ─────────────────────────────────────────────────────────────────────────────

model RiskAlert {
  id       String          @id @default(uuid())
  category RiskCategory
  severity RiskSeverity
  status   RiskAlertStatus @default(OPEN)

  title       String
  description String @db.Text

  clubId          String?
  franchiseUnitId String?
  investorId      String?
  entityId        String?

  sourceEngine String
  sourceRef    String?
  fingerprint  String  @unique

  score Float?

  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String?   @db.Text
  dueByAt        DateTime?

  workflowId String?
  workflow   ExecutiveWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity])
  @@index([category])
  @@index([clubId])
  @@index([franchiseUnitId])
  @@index([investorId])
  @@index([entityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Executive audit — board-grade, cross-engine
// ─────────────────────────────────────────────────────────────────────────────

model ExecutiveAudit {
  id            String  @id @default(uuid())
  workflowId    String?
  resolutionId  String?
  alertId       String?
  forecastId    String?
  opportunityId String?

  userId       String?
  action       String
  category     ExecutiveAuditCategory
  resourceType String?
  resourceId   String?

  metadata  Json?
  ipAddress String?
  userAgent String?

  result  ExecutiveAuditResult @default(SUCCESS)
  message String?              @db.Text

  createdAt DateTime @default(now())

  @@index([workflowId])
  @@index([resolutionId])
  @@index([action])
  @@index([category])
  @@index([createdAt])
}

// =============================================================================
// Phase Q · Football Intelligence Models
// =============================================================================

enum DataProviderSource {
  MANUAL
  STATSBOMB
  OPTA
  WYSCOUT
  INSTAT
  TRACAB
  SECONDSPECTRUM
  HUDL
  INTERNAL
}

model DataProviderSession {
  id      String @id @default(uuid())
  clubId  String
  matchId String?

  source         DataProviderSource @default(MANUAL)
  status         String             @default("RUNNING")
  eventsIngested Int                @default(0)
  eventsRejected Int                @default(0)
  errorLog       Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId, matchId])
  @@index([status])
}

// ── Video Coaching Intelligence ───────────────────────────────────────────────

model VideoClip {
  id      String     @id @default(uuid())
  assetId String
  asset   VideoAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  clubId  String

  title          String?
  description    String?   @db.Text
  startSec       Float
  endSec         Float
  durationSec    Float?
  eventId        String?
  teamId         String?
  playerId       String?
  matchId        String?
  shareToken     String?   @unique
  shareExpiresAt DateTime?
  sharedWithIds  String[]
  tags           String[]

  annotations VideoAnnotation[]

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([clubId])
  @@index([shareToken])
  @@index([matchId])
  @@index([playerId])
}

model VideoAnnotation {
  id     String    @id @default(uuid())
  clipId String
  clip   VideoClip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  clubId String

  frameTimeSec Float
  shape        String  @default("TEXT")
  x            Float   @default(0.5)
  y            Float   @default(0.5)
  x2           Float?
  y2           Float?
  points       Json?
  color        String  @default("#FF0000")
  text         String? @db.Text
  labelText    String?
  strokeWidth  Float   @default(2)
  opacity      Float   @default(1.0)
  durationSec  Float?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clipId, frameTimeSec])
  @@index([clubId])
}

model VideoPlaylist {
  id          String  @id @default(uuid())
  clubId      String
  title       String
  description String? @db.Text
  teamId      String?

  clipIds String[]
  items   VideoPlaylistItem[]

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([teamId])
}

model VideoPlaylistItem {
  id         String        @id @default(uuid())
  playlistId String
  playlist   VideoPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  clipId     String
  position   Int
  clubId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playlistId, clipId])
  @@index([playlistId, position])
  @@index([clubId])
}

// ── Workload Science ──────────────────────────────────────────────────────────

model GPSTrackingSession {
  id       String @id @default(uuid())
  clubId   String
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  matchId           String?
  trainingSessionId String?
  deviceSerial      String?

  startedAt   DateTime
  endedAt     DateTime?
  durationMin Float     @default(0)

  totalDistanceM     Float
  highSpeedDistanceM Float @default(0)
  veryHighSpeedDistM Float @default(0)
  sprintDistanceM    Float @default(0)
  maxSpeedKph        Float
  avgSpeedKph        Float @default(0)
  accelerations      Int   @default(0)
  decelerations      Int   @default(0)
  highAccelerations  Int   @default(0)
  playerLoad         Float @default(0)

  zoneBreakdown   Json?
  heartRateAvg    Float?
  heartRateMax    Float?
  hrZoneBreakdown Json?
  rawDataRef      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([playerId, startedAt])
}

model WorkloadRecord {
  id       String @id @default(uuid())
  clubId   String
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  weekStart             DateTime
  acuteLoad             Float
  chronicLoad           Float
  trainingStressBalance Float
  acwr                  Float
  monotony              Float   @default(0)
  strain                Float   @default(0)
  isHighRisk            Boolean @default(false)
  injuryRiskScore       Float   @default(0)
  riskFlags             Json?

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([playerId, weekStart])
  @@index([clubId])
  @@index([playerId])
  @@index([isHighRisk])
}

model InjuryRecord {
  id       String @id @default(uuid())
  clubId   String
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  recordedBy String?

  injuryDate       DateTime
  bodyLocation     String
  bodyLocationCode String?
  osicsCategory    String?
  mechanism        String  @default("UNKNOWN")
  severity         String?
  isContactInjury  Boolean @default(false)
  isRecurrence     Boolean @default(false)

  matchId    String?
  trainingId String?

  workloadAtInjury Float?
  notes            String? @db.Text

  returnDate DateTime?
  daysAbsent Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([playerId, injuryDate])
  @@index([returnDate])
}

// ── Transfer Intelligence ─────────────────────────────────────────────────────

model TransferTarget {
  id       String @id @default(uuid())
  clubId   String
  playerId String

  stage           String    @default("LONGLIST")
  position        String?
  preferredFoot   String?
  nationality     String?
  currentClubName String?
  askingPriceMEur Float?
  budgetCapMEur   Float?
  priorityScore   Int       @default(50)
  notes           String?   @db.Text
  archivedAt      DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId, stage])
  @@index([clubId, archivedAt])
  @@index([playerId])
}

model PlayerMarketValue {
  id       String @id @default(uuid())
  clubId   String
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  valuationDate DateTime
  valueMEur     Float
  source        String
  notes         String? @db.Text
  recordedBy    String?

  createdAt DateTime @default(now())

  @@index([clubId, playerId, valuationDate])
  @@index([playerId, valuationDate])
}

model PlayerContractStatus {
  id       String @id @default(uuid())
  clubId   String
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  contractExpiry         DateTime
  contractValueEur       Float?
  releaseClauseEur       Float?
  agentName              String?
  agentContact           String?
  expiryAlertDays        Int     @default(180)
  isExpiringSoon         Boolean @default(false)
  isAvailableForTransfer Boolean @default(false)
  notes                  String? @db.Text
  updatedBy              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([contractExpiry])
  @@index([isExpiringSoon])
}

// ── Player Statistics ─────────────────────────────────────────────────────────

model PlayerMatchStats {
  id       String @id @default(uuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubId   String
  teamId   String?

  minutesPlayed      Int     @default(0)
  isStarting         Boolean @default(false)
  goals              Int     @default(0)
  assists            Int     @default(0)
  shots              Int     @default(0)
  shotsOnTarget      Int     @default(0)
  shotsBlocked       Int     @default(0)
  xg                 Float   @default(0)
  xgot               Float   @default(0)
  xa                 Float   @default(0)
  keyPasses          Int     @default(0)
  bigChancesCreated  Int     @default(0)
  passes             Int     @default(0)
  passesCompleted    Int     @default(0)
  passAccuracy       Float   @default(0)
  progressivePasses  Int     @default(0)
  carries            Int     @default(0)
  progressiveCarries Int     @default(0)
  dribbles           Int     @default(0)
  dribblesCompleted  Int     @default(0)
  pressures          Int     @default(0)
  pressuresSuccessful Int    @default(0)
  tackles            Int     @default(0)
  tacklesWon         Int     @default(0)
  interceptions      Int     @default(0)
  clearances         Int     @default(0)
  blockedShots       Int     @default(0)
  aerialDuels        Int     @default(0)
  aerialDuelsWon     Int     @default(0)
  groundDuels        Int     @default(0)
  groundDuelsWon     Int     @default(0)
  foulsCommitted     Int     @default(0)
  foulsSuffered      Int     @default(0)
  yellowCards        Int     @default(0)
  redCards           Int     @default(0)
  offsides           Int     @default(0)
  heatmapGrid        Json?
  ratingFamilista    Float?
  computedAt         DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([clubId])
}

model PlayerSeasonStats {
  id            String      @id @default(uuid())
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubId        String
  season        String
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id])

  appearances         Int   @default(0)
  starts              Int   @default(0)
  minutesPlayed       Int   @default(0)
  goals               Int   @default(0)
  assists             Int   @default(0)
  xg                  Float @default(0)
  xa                  Float @default(0)
  xgPer90             Float @default(0)
  xaPer90             Float @default(0)
  goalsPer90          Float @default(0)
  assistsPer90        Float @default(0)
  passAccuracy        Float @default(0)
  pressureSuccessRate Float @default(0)
  aerialSuccessRate   Float @default(0)
  dribbleSuccessRate  Float @default(0)
  averageRating       Float @default(0)
  avgDistancePer90    Float @default(0)
  avgSprintsPer90     Float @default(0)

  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([playerId, clubId, season, competitionId])
  @@index([playerId])
  @@index([clubId, season])
  @@index([competitionId])
}

// ── Competition Engine ────────────────────────────────────────────────────────

model Competition {
  id     String @id @default(uuid())
  clubId String

  name        String
  code        String
  season      String
  format      String  @default("LEAGUE")
  ageGroup    String?
  gender      String?
  countryCode String?
  description String? @db.Text

  teams       CompetitionTeam[]
  fixtures    Fixture[]
  seasonStats PlayerSeasonStats[]

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, code, season])
  @@index([clubId, season])
}

model CompetitionTeam {
  id            String      @id @default(uuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  teamId        String
  clubId        String

  createdAt DateTime @default(now())

  @@unique([competitionId, teamId])
  @@index([competitionId])
  @@index([teamId])
}

model Fixture {
  id            String      @id @default(uuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  clubId        String
  homeTeamId    String
  awayTeamId    String

  scheduledAt DateTime
  venue       String?
  round       Int?
  leg         Int?
  status      String  @default("SCHEDULED")

  homeScore     Int?
  awayScore     Int?
  homeScoreAet  Int?
  awayScoreAet  Int?
  homePenalties Int?
  awayPenalties Int?
  playedAt      DateTime?

  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([competitionId, round])
  @@index([clubId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([matchId])
  @@index([status])
}

model StandingsEntry {
  id            String @id @default(uuid())
  competitionId String
  teamId        String
  position      Int
  played        Int    @default(0)
  won           Int    @default(0)
  drawn         Int    @default(0)
  lost          Int    @default(0)
  goalsFor      Int    @default(0)
  goalsAgainst  Int    @default(0)
  goalDiff      Int    @default(0)
  points        Int    @default(0)
  form          String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([competitionId, teamId])
  @@index([competitionId, position])
}

// ─────────────────────────────────────────────────────────────────────────────
// Scouting & Recruitment Center — ScoutProspect
// ─────────────────────────────────────────────────────────────────────────────
// Single comprehensive model for external player scouting.
// Does NOT require a Player FK — prospects are external players not yet in the squad.
// Recruitment pipeline: IDENTIFIED → SCOUTED → REVIEWED → NEGOTIATION
//                      → TRIAL → APPROVED → SIGNED | REJECTED
// ─────────────────────────────────────────────────────────────────────────────

model ScoutProspect {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // ── Basic profile ──────────────────────────────────────────────────────────
  playerName         String
  dateOfBirth        DateTime?
  age                Int?
  nationality        String?
  currentClub        String?
  league             String?
  position           String
  secondaryPositions String[]
  preferredFoot      String?       // RIGHT | LEFT | BOTH
  heightCm           Int?
  weightKg           Int?

  // ── Market intelligence ────────────────────────────────────────────────────
  marketValueEur     Float?
  contractUntil      DateTime?
  agentName          String?

  // ── Scout metadata ─────────────────────────────────────────────────────────
  scoutName          String?
  reportDate         DateTime?

  // ── Recruitment pipeline status ────────────────────────────────────────────
  // IDENTIFIED | SCOUTED | REVIEWED | NEGOTIATION | TRIAL | APPROVED | SIGNED | REJECTED
  status             String    @default("IDENTIFIED")

  // ── Technical evaluation (1–100) ───────────────────────────────────────────
  pace               Int?
  acceleration       Int?
  agility            Int?
  dribbling          Int?
  ballControl        Int?
  passing            Int?
  vision             Int?
  crossing           Int?
  finishing          Int?
  shooting           Int?
  heading            Int?
  tackling           Int?
  positioning        Int?
  composure          Int?
  decisionMaking     Int?

  // ── Physical evaluation (1–100) ────────────────────────────────────────────
  strength           Int?
  stamina            Int?
  endurance          Int?
  balance            Int?
  mobility           Int?
  explosiveness      Int?

  // ── Mental evaluation (1–100) ──────────────────────────────────────────────
  leadership         Int?
  discipline         Int?
  concentration      Int?
  workRate           Int?
  determination      Int?
  professionalism    Int?
  coachability       Int?

  // ── Calculated scores (auto-computed on save) ──────────────────────────────
  currentRating      Float?
  potentialRating    Float?
  recommendationScore Float?
  // REJECT | MONITOR | INTERESTING | STRONG_TARGET | PRIORITY_TARGET
  recommendation     String?

  // ── Position fit (0–100, computed) ─────────────────────────────────────────
  fitGK              Int?
  fitCB              Int?
  fitFB              Int?
  fitDM              Int?
  fitCM              Int?
  fitAM              Int?
  fitWinger          Int?
  fitStriker         Int?

  // ── Risk assessment ────────────────────────────────────────────────────────
  injuryRisk         String?   // LOW | MEDIUM | HIGH
  adaptationRisk     String?
  disciplineRisk     String?
  financialRisk      String?

  // ── Scout report text fields ───────────────────────────────────────────────
  strengths          String?   @db.Text
  weaknesses         String?   @db.Text
  tacticalFit        String?   @db.Text
  developmentAreas   String?   @db.Text
  comments           String?   @db.Text
  finalRecommendation String?  @db.Text

  // ── Watchlist ──────────────────────────────────────────────────────────────
  isOnWatchlist      Boolean   @default(false)
  // TRANSFER_TARGET | FUTURE_PROSPECT | TRIAL_CANDIDATE | ACADEMY_PROSPECT
  watchlistCategory  String?
  watchlistPriority  Int       @default(50)
  followUpDate       DateTime?

  // ── Audit ──────────────────────────────────────────────────────────────────
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clubId, status])
  @@index([clubId, position])
  @@index([clubId, isOnWatchlist])
  @@index([clubId, recommendation])
  @@index([clubId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Club Home Dashboard — Announcements
// ─────────────────────────────────────────────────────────────────────────────

enum AnnouncementPriority {
  HIGH
  NORMAL
  LOW
}

model Announcement {
  id        String               @id @default(uuid())
  clubId    String
  title     String               @db.VarChar(200)
  body      String               @db.Text
  priority  AnnouncementPriority @default(NORMAL)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  club      Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt(sort: Desc)])
}
