  @@index([userId, isActive])
}

model OpsReportTemplate {
  id          String   @id @default(uuid())
  clubId      String? // null = global template
  code        String
  label       String
  /// Definition for a deterministic report; JSON includes sources + filters.
  definition  Json
  isActive    Boolean  @default(true)
  publishedBy String?
  publishedAt DateTime @default(now())

  @@unique([clubId, code])
  @@index([code, isActive])
}

model OpsReportRun {
  id         String    @id @default(uuid())
  clubId     String
  templateId String
  parameters Json
  /// Final rendered output (CSV/JSON).
  output     Json
  /// SHA-256 of the canonical output — replay-anchor.
  outputHash String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([clubId, startedAt])
  @@index([templateId])
}

// ── Data governance ─────────────────────────────────────────────────────

model DataRetentionPolicy {
  id            String   @id @default(uuid())
  clubId        String? // null = global default
  entityType    String // "MatchTimeline" | "SensorPacket" | "AIAlert" | …
  retentionDays Int // 0 = forever (audit chain exception)
  isActive      Boolean  @default(true)
  publishedBy   String?
  publishedAt   DateTime @default(now())

  @@unique([clubId, entityType])
  @@index([entityType, isActive])
}

/// Unified GDPR request (export / delete / rectification / portability).
model GdprDataRequest {
  id               String           @id @default(uuid())
  clubId           String?
  requestingUserId String
  subjectUserId    String?
  subjectPlayerId  String?
  kind             GdprRequestKind
  state            GdprRequestState @default(PENDING)
  scope            Json? // entity types in scope
  payloadHash      String?
  completedAt      DateTime?
  /// Download URL when state=COMPLETED for EXPORT.
  resultRef        String?
  /// Reason if REJECTED.
  rejectedReason   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([clubId, kind, state])
  @@index([subjectUserId])
  @@index([subjectPlayerId])
}

model UserConsentRecord {
  id        String       @id @default(uuid())
  clubId    String?
  userId    String?
  playerId  String?
  scope     ConsentScope
  granted   Boolean      @default(true)
  payload   Json?
  grantedAt DateTime     @default(now())
  revokedAt DateTime?

  @@index([userId, scope])
  @@index([playerId, scope])
  @@index([clubId, scope])
}

// ── Monitoring ──────────────────────────────────────────────────────────

model ProductionHealthCheck {
  id         String           @id @default(uuid())
  service    String // "db" | "redis" | "outbox" | "worker" | …
  state      HealthCheckState @default(OK)
  latencyMs  Int?
  payload    Json?
  capturedAt DateTime         @default(now())

  @@index([service, capturedAt])
  @@index([state, capturedAt])
}

model ProductionAlertRule {
  id             String         @id @default(uuid())
  clubId         String? // null = global rule
  code           String
  label          String
  expression     String         @db.Text // free-text rule body
  threshold      Float?
  channelTargets Json?
  state          AlertRuleState @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([clubId, code])
  @@index([state])
}

// ── Deployment automation ──────────────────────────────────────────────

model BackupRecord {
  id         String     @id @default(uuid())
  kind       BackupKind @default(SCHEDULED)
  /// Backup ref (S3 URL, Render snapshot id, etc.).
  ref        String?
  sizeBytes  BigInt?
  sha256     String?
  notes      String?
  startedAt  DateTime   @default(now())
  finishedAt DateTime?
  ok         Boolean    @default(true)

  @@index([kind, startedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase P · Real Launch — in-app notification inbox
// ─────────────────────────────────────────────────────────────────────────
// Single additive model used by the in-app inbox. Dispatch to email/SMS/push
// is intentionally out of scope; channels are registered via Phase O
// `UserNotificationChannel` and dispatched by a future worker.

model UserNotification {
  id        String               @id @default(uuid())
  clubId    String
  userId    String
  kind      UserNotificationKind @default(SYSTEM)
  title     String
  body      String?              @db.Text
  payload   Json?
  readAt    DateTime?
  archived  Boolean              @default(false)
  createdAt DateTime             @default(now())

  @@index([clubId])
  @@index([userId, archived, readAt])
  @@index([createdAt])
}

enum UserNotificationKind {
  SYSTEM
  ATTENDANCE_REMINDER
  PAYMENT_REMINDER
  TRAINING_UPDATE
  INJURY_ALERT
  DEVICE_ALERT
  GDPR_UPDATE
}

model Tournament {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  name         String
  type         CompetitionType
  season       String          @default("2024-25")
  teams        Int             @default(16)
  position     Int?
  points       Int?
  played       Int             @default(0)
  won          Int             @default(0)
  drawn        Int             @default(0)
  lost         Int             @default(0)
  goalsFor     Int             @default(0)
  goalsAgainst Int             @default(0)
  isActive     Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
}

model TrainingSession {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  location      String?
  scheduledAt   DateTime
  duration      Int
  drills        DrillType[]
  attackForm    Int         @default(12)
  defenseForm   Int         @default(14)
  possession    Int         @default(11)
  conditionForm Int         @default(13)

  // ── Training-persistence additions (all optional/defaulted so the migration is additive & safe) ──
  // These mirror the fields the Training workspace already tracks client-side, so a session can be
  // fully persisted in PostgreSQL (planning → completion) instead of localStorage.
  startTime     String?              // "10:00"
  sessionType   String?              // technical | tactical | physical | recovery | gym | mental | match
  objective     String?
  tacticalFocus String?
  formation     String?
  status        String   @default("planned")   // draft | planned | in_progress | completed | cancelled
  sessionRating Float?
  bestPlayerId  String?              // Player.id of the session's best performer
  coachNote     String?  @db.Text
  completedAt   DateTime?

  // ── Session-analytics additions (all optional so the migration is additive & safe) ──
  // Real coach-entered session context — persisted so Session Analytics reads real data.
  intensity     String?              // Low | Medium | High | Max
  pitch         String?
  weather       String?
  temperature   String?
  equipment     String?
  coachName     String?

  playerStats PlayerTrainingStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([scheduledAt])
  @@index([status])
}

model PlayerTrainingStat {
  id        String          @id @default(uuid())
  sessionId String
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  attended      Boolean @default(true)
  rating        Float?
  notes         String?
  participation String?             // full | partial (persisted training participation, additive)

  @@unique([sessionId, playerId])
  @@index([sessionId])
  @@index([playerId])
}

model GpsDevice {
  id            String  @id @default(uuid())
  serialNumber  String  @unique
  firmware      String  @default("v1.2")
  isOnline      Boolean @default(false)
  batteryLevel  Int     @default(100)
  signalQuality Int     @default(100)

  clubId   String
  club     Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId String? @unique
  player   Player? @relation(fields: [playerId], references: [id])

  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([clubId])
}

model ScoutReport {
  id             String              @id @default(uuid())
  clubId         String
  club           Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  targetName     String
  targetClub     String
  position       PlayerPosition
  age            Int
  nationality    String
  flag           String
  marketValue    Float
  rating         Float
  recommendation ScoutRecommendation
  notes          String?
  isActive       Boolean             @default(true)

  createdAt DateTime @default(now())

  @@index([clubId])
}

model Financial {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  type        TransactionType
  category    String
  amount      Float
  currency    String          @default("EUR")
  description String?
  date        DateTime        @default(now())

  createdAt DateTime @default(now())

  @@index([clubId])
  @@index([date])
  @@index([type])
}

model AiInsight {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     String
  prompt   String  @db.Text
  response String  @db.Text
  model    String  @default("claude-sonnet-4-20250514")
  tokens   Int?
  playerId String?

  createdAt DateTime @default(now())

  @@index([clubId])
  @@index([userId])
  @@index([type])
}

// Familista — White-label Engine
// Additive Prisma fragment. Merge into the main schema.prisma.
//
// Required edit to existing Club model — add this relation field:
//   whiteLabel WhiteLabelConfig?
//
// Run: npx prisma migrate dev --name whitelabel_engine

enum WhiteLabelDomainStatus {
  PENDING
  VERIFYING
  ACTIVE
  FAILED
  DISABLED
}

enum WhiteLabelAuditAction {
  CONFIG_CREATED
  CONFIG_UPDATED
  CONFIG_RESET
  DOMAIN_ADDED
  DOMAIN_REMOVED
  DOMAIN_VERIFIED
  DOMAIN_FAILED
  DOMAIN_PROMOTED
  ASSET_REPLACED
}

model WhiteLabelConfig {
  id     String @id @default(uuid())
  clubId String @unique
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // Brand identity
  productName String?
  tagline     String?
  logoUrl     String?
  logoDarkUrl String?
  faviconUrl  String?
  ogImageUrl  String?

  // Color tokens (validated as #RRGGBB or #RRGGBBAA)
  primaryColor    String @default("#0f172a")
  secondaryColor  String @default("#64748b")
  accentColor     String @default("#22c55e")
  backgroundColor String @default("#ffffff")
  surfaceColor    String @default("#f8fafc")
  textColor       String @default("#0f172a")
  mutedTextColor  String @default("#64748b")
  borderColor     String @default("#e2e8f0")
  errorColor      String @default("#ef4444")
  successColor    String @default("#22c55e")
  warningColor    String @default("#f59e0b")

  // Typography
  fontFamily     String  @default("Inter, system-ui, -apple-system, sans-serif")
  fontHeadingUrl String?
  fontBodyUrl    String?

  // Public links
  supportEmail String?
  supportUrl   String?
  termsUrl     String?
  privacyUrl   String?
  marketingUrl String?

  // Email branding
  emailFromName   String?
  emailFromEmail  String?
  emailReplyTo    String?
  emailHeaderHtml String? @db.Text
  emailFooterHtml String? @db.Text

  // Behavior toggles
  hidePoweredBy   Boolean @default(false)
  hideInvestor    Boolean @default(true)
  hideMarketplace Boolean @default(false)

  // Advanced
  customCss      String? @db.Text
  customHeadHtml String? @db.Text
  defaultLocale  String  @default("en")
  metadata       Json?

  // Versioning / lifecycle
  isActive    Boolean   @default(true)
  version     Int       @default(1)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  domains WhiteLabelDomain[]
  audits  WhiteLabelAudit[]
  assets  WhiteLabelAsset[]

  @@index([clubId])
  @@index([isActive])
}

model WhiteLabelDomain {
  id       String           @id @default(uuid())
  configId String
  config   WhiteLabelConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  hostname      String                 @unique
  isPrimary     Boolean                @default(false)
  status        WhiteLabelDomainStatus @default(PENDING)
  verifyToken   String                 @unique
  verifyHost    String?
  verifiedAt    DateTime?
  lastCheckedAt DateTime?
  failureReason String?
  sslIssuedAt   DateTime?
  sslExpiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId])
  @@index([status])
  @@index([hostname])
}

model WhiteLabelAudit {
  id       String           @id @default(uuid())
  configId String
  config   WhiteLabelConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  userId    String?
  action    WhiteLabelAuditAction
  changes   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([configId])
  @@index([createdAt])
  @@index([action])
}

// Familista — Super Admin White-label Control Panel
// Additive Prisma fragment. Merge into the main schema.prisma AFTER the
// white-label engine fragment (`whitelabel.schema.prisma`).
//
// Required edits to existing models:
//
//   model Club {
//     ...
//     limits              OrganizationLimits?
//     subscriptionOverrides SubscriptionOverride[]
//     platformAuditLogs   PlatformAuditLog[]
//
//     // Source-of-truth for plan resolution. When set to OVERRIDE the
//     // Stripe webhook MUST NOT mutate Club.plan / subscriptionStatus.
//     planSource          PlanSource @default(STRIPE)
//   }
//
//   model User {
//     ...
//     platformAdmin       PlatformAdmin?
//     impersonations      ImpersonationSession[] @relation("ImpersonationTarget")
//   }
//
//   model WhiteLabelConfig {
//     ...
//     assets              WhiteLabelAsset[]
//   }
//
// Run: npx prisma migrate dev --name admin_whitelabel_panel

enum PlanSource {
  STRIPE
  OVERRIDE
}

enum PlatformRole {
  PLATFORM_OWNER
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
  PLATFORM_BILLING
  PLATFORM_READ_ONLY
}

enum AssetType {
  LOGO_LIGHT
  LOGO_DARK
  FAVICON
  OG_IMAGE
  PDF_HEADER
  PDF_FOOTER
  EMAIL_HEADER_BG
}

enum AssetStorage {
  LOCAL
  S3
  EXTERNAL_URL
}

enum PlatformAuditCategory {
  BRANDING
  DOMAIN
  ASSET
  PALETTE
  BILLING
  LICENSE
  LIMITS
  ACCESS
  IMPERSONATION
  FEATURE_FLAG
  PLATFORM_ADMIN
  OTHER
}

enum PlatformAuditResult {
  SUCCESS
  FAILURE
  REJECTED
}

enum ImpersonationStatus {
  ACTIVE
  ENDED
  EXPIRED
  REVOKED
}

// ─────────────────────────────────────────────────────────────────────────────
// Platform admin RBAC
// ─────────────────────────────────────────────────────────────────────────────

model PlatformAdmin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        PlatformRole
  ipAllowlist String[]     @default([]) // CIDRs or exact IPs
  mfaEnforced Boolean      @default(true)
  isActive    Boolean      @default(true)

  invitedBy  String?
  acceptedAt DateTime?
  lastSeenAt DateTime?
  notes      String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs      PlatformAuditLog[]
  impersonations ImpersonationSession[]

  @@index([role])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// White-label assets (logos, favicons, OG images, PDF/email assets)
// ─────────────────────────────────────────────────────────────────────────────

model WhiteLabelAsset {
  id       String           @id @default(uuid())
  configId String
  config   WhiteLabelConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  type       AssetType
  storage    AssetStorage @default(LOCAL)
  bucket     String?
  storageKey String?
  url        String

  contentType String
  bytes       Int
  width       Int?
  height      Int?
  checksum    String

  uploadedBy String?
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId, type])
  @@index([type])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// Color palette templates (system presets + custom saved palettes)
// ─────────────────────────────────────────────────────────────────────────────

model ColorPaletteTemplate {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?

  isSystem Boolean @default(false)
  isPublic Boolean @default(true)
  category String  @default("custom") // "system", "league", "club", "custom"

  tokens  Json
  preview String? // optional preview image url

  createdBy  String?
  usageCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isSystem])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────────────────────
// Per-organization limits (quotas) and feature overrides
// ─────────────────────────────────────────────────────────────────────────────

model OrganizationLimits {
  id     String @id @default(uuid())
  clubId String @unique
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  maxUsers                Int?
  maxPlayers              Int?
  maxGpsDevices           Int?
  maxStorageMb            Int?
  maxApiCallsPerDay       Int?
  maxAiInsightsPerMonth   Int?
  maxCustomDomains        Int?
  maxPdfReportsPerMonth   Int?
  maxImpersonationsPerDay Int?

  featuresEnabled  String[] @default([])
  featuresDisabled String[] @default([])

  notes String? @db.Text
  setBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Subscription overrides (operator-granted plan/status, audited)
// ─────────────────────────────────────────────────────────────────────────────

model SubscriptionOverride {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  plan         SubscriptionPlan
  status       SubscriptionStatus
  reason       String             @db.Text
  expiresAt    DateTime?
  bypassStripe Boolean            @default(false)

  appliedBy     String
  revokedBy     String?
  revokedAt     DateTime?
  revokedReason String?   @db.Text

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([isActive])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Feature flag definitions and plan matrix
// ─────────────────────────────────────────────────────────────────────────────

model FeatureFlag {
  id              String             @id @default(uuid())
  key             String             @unique
  name            String
  description     String?            @db.Text
  defaultEnabled  Boolean            @default(false)
  enabledForPlans SubscriptionPlan[] @default([])
  isInternal      Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Impersonation sessions
// ─────────────────────────────────────────────────────────────────────────────

model ImpersonationSession {
  id      String        @id @default(uuid())
  adminId String
  admin   PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  targetUserId String
  targetUser   User   @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetClubId String

  tokenHash   String              @unique
  reason      String              @db.Text
  expiresAt   DateTime
  endedAt     DateTime?
  endedReason String?
  status      ImpersonationStatus @default(ACTIVE)

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([targetClubId])
  @@index([expiresAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cross-tenant platform audit log
// ─────────────────────────────────────────────────────────────────────────────

model PlatformAuditLog {
  id      String         @id @default(uuid())
  adminId String?
  admin   PlatformAdmin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  userId String?
  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id], onDelete: SetNull)

  action       String
  category     PlatformAuditCategory
  resourceType String?
  resourceId   String?

  metadata  Json?
  ipAddress String?
  userAgent String?

  result  PlatformAuditResult @default(SUCCESS)
  message String?             @db.Text

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([clubId])
  @@index([action])
  @@index([category])
  @@index([result])
  @@index([createdAt])
}

