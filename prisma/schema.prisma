  RECRUITMENT
  MEDICAL_EXEC
  FINANCE_EXEC
  MARKETING
  ACADEMY_HEAD
  PERFORMANCE
}

enum CouncilStatus {
  OPEN
  VOTING
  CLOSED
}

enum CouncilVoteType {
  APPROVE
  REJECT
  ABSTAIN
}

enum RecruitmentStatus {
  LEAD
  SCOUTED
  EVALUATED
  TARGETED
  OFFERED
  SIGNED
  REJECTED
  LOST
}

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELED
}

enum MarketplaceItemKind {
  TRANSFER_LISTING
  DEVICE_LISTING
  SERVICE_LISTING
  ACADEMY_PROGRAM
  GENERIC
}

enum MarketplaceItemStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum KnowledgeNodeKind {
  TACTICAL
  MEDICAL
  ECONOMIC
  SCOUTING
  GENERAL
}

