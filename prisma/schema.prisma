// Familista - Production Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CLUB_ADMIN
  HEAD_COACH
  ASSISTANT_COACH
  ANALYST
  MEDICAL_STAFF
  SCOUT
  // Phase O additions — additive only.
  MANAGER
  COACH
  PARENT
  PLAYER
}

enum SubscriptionPlan {
  BASIC
  PRO
  ACADEMY
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum PlayerPosition {
  GK
  DC
  DL
  DR
  DMC
  ML
  MR
  MC
  AMC
  AML
  AMR
  ST
}

enum Foot {
  RIGHT
  LEFT
  BOTH
}

enum MatchResult {
  WIN
  DRAW
  LOSS
}

enum CompetitionType {
  LEAGUE
  CUP
  FRIENDLY
  ELITE
  ASSOCIATION
}

enum InjurySeverity {
  MINOR
  MODERATE
  SERIOUS
  CRITICAL
}

enum DrillType {
  TECHNICAL_PASSING
  SPRINT_INTERVALS
  SHOOTING_PRACTICE
  DEFENSIVE_SHAPE
  TRANSITION_PLAY
  RECOVERY
  SET_PIECES
  POSSESSION
  PRESSING
  CUSTOM
}

enum ScoutRecommendation {
  SIGN
  MONITOR
  SKIP
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Club {
  id             String    @id @default(uuid())
  name           String
  shortName      String?
  emblem         String?
  city           String
  country        String    @default("Germany")
  founded        DateTime?
  stadium        String?
  capacity       Int?
  level          Int       @default(1)
  overallRating  Float     @default(70.0)
  leaguePosition Int?
  fanClub        String?

  // ── Club profile (Phase R — Club System). All nullable / additive. ──
  description    String?   @db.Text
  addressLine    String?
  region         String?
  postalCode     String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  socialLinks    Json?

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 SubscriptionPlan   @default(BASIC)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  users            User[]
  players          Player[]
  matches          Match[]
  tournaments      Tournament[]
  trainingSessions TrainingSession[]
  financials       Financial[]
  devices          GpsDevice[]
  aiInsights       AiInsight[]
  scoutReports     ScoutReport[]

  // ── Cross-engine bridges (additive go-live merge) ──
  whiteLabel            WhiteLabelConfig?
  limits                OrganizationLimits?
  subscriptionOverrides SubscriptionOverride[]
  platformAuditLogs     PlatformAuditLog[]
  planSource            PlanSource             @default(STRIPE)
  franchiseUnitId       String?
  franchiseUnit         FranchiseUnit?         @relation(fields: [franchiseUnitId], references: [id], onDelete: SetNull)
  revenueDistributions  RevenueDistribution[]
  investmentEntity      InvestmentEntity?

  // ── Phase A: multi-tenant teams + memberships ──
  teams            Team[]
  memberships      Membership[]
  membershipAudits MembershipAuditLog[]
  currentUsers     User[]               @relation("UserCurrentClub")

  // ── Scouting & Recruitment Center ──
  scoutProspects   ScoutProspect[]

  // ── Club Home Dashboard ──
  announcements    Announcement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
  @@index([franchiseUnitId])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole @default(HEAD_COACH)
  avatar       String?
  isActive     Boolean  @default(true)

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]
  aiInsights      AiInsight[]

  // ── Cross-engine bridges (additive go-live merge) ──
  platformAdmin   PlatformAdmin?
  impersonations  ImpersonationSession[] @relation("ImpersonationTarget")
  franchiseOwner  FranchiseOwner?
  investorProfile InvestorProfile?

  // ── Phase A: multi-tenant Memberships + active context ──
  memberships      Membership[]
  currentClubId    String?
  currentClub      Club?                @relation("UserCurrentClub", fields: [currentClubId], references: [id], onDelete: SetNull)
  currentTeamId    String?
  currentTeam      Team?                @relation("UserCurrentTeam", fields: [currentTeamId], references: [id], onDelete: SetNull)
  membershipAudits MembershipAuditLog[] @relation("MembershipAuditActor")

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clubId])
  @@index([email])
  @@index([currentClubId])
  @@index([currentTeamId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ── Password reset tokens (single-use, 1h TTL, SHA-256 stored) ──────────────
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique   // SHA-256(rawToken) — raw token never persisted
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Player {
  id            String         @id @default(uuid())
  firstName     String
  lastName      String
  number        Int
  position      PlayerPosition
  nationality   String
  flag          String
  dateOfBirth   DateTime
  height        Int
  weight        Int
  preferredFoot Foot           @default(RIGHT)
  overallRating Int            @default(70)
  potential     Int            @default(70)
  condition     Int            @default(100)
  isInjured     Boolean        @default(false)
  marketValue   Float          @default(1000000)
  weeklyWage    Int            @default(10000)
  contractUntil DateTime?
  avatar        String?

  // ── Phase 2 additions (all default-valued so the migration is safe) ──
  email         String?
  parentName    String?
  parentEmail   String?
  parentPhone   String?
  medicalStatus MedicalStatus @default(HEALTHY)
  paymentStatus PaymentStatus @default(PAID)
  isActive      Boolean       @default(true)
  notes         String?       @db.Text

  // ── Squad-migration additions (Training/Squad phase — all optional/defaulted so the migration is additive & safe) ──
  // legacyId provides a stable, idempotent mapping from the old client-side Squad id (e.g. "sq-8")
  // to this backend Player UUID, so the import can run more than once without creating duplicates.
  legacyId         String?  @unique
  roles            String?              // e.g. "BBM · CM" (preserved from the Squad UI)
  morale           String?              // "Excellent" | "Good" | "Content" | "Poor"
  isCaptain        Boolean  @default(false)
  isViceCaptain    Boolean  @default(false)
  trainedPositions String?              // comma-separated allowed positions (e.g. "CM,DM,AM")
  joinedAt      DateTime      @default(now())

  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // ── Phase A: optional team scoping ──
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  attributes    PlayerAttribute[]
  gpsData       PlayerGpsData[]
  matchStats    PlayerMatchStat[]
  trainingStats PlayerTrainingStat[]
  injuries      PlayerInjury[]
  device        GpsDevice?
  auditLogs     PlayerAuditLog[]

  // ── Phase Q back-relations ──
  gpsSessions      GPSTrackingSession[]
  workloadRecords  WorkloadRecord[]
  injuryRecords    InjuryRecord[]
  playerMatchStats PlayerMatchStats[]
  playerSeasonStats PlayerSeasonStats[]
  marketValues     PlayerMarketValue[]
  contractStatus   PlayerContractStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([position])
  @@index([isActive])
  @@index([medicalStatus])
  @@index([paymentStatus])
}

// Audit trail of every privileged write against a Player.
// Soft-delete + status transitions all leave a row here.
model PlayerAuditLog {
  id        String            @id @default(uuid())
  playerId  String
  player    Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubId    String
  userId    String?
  action    PlayerAuditAction
  before    Json?
  after     Json?
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime          @default(now())

  @@index([playerId])
  @@index([clubId])
  @@index([action])
  @@index([createdAt])
}

enum MedicalStatus {
  HEALTHY
  INJURED
  RECOVERING
  SUSPENDED
  UNAVAILABLE
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
  OVERDUE
  EXEMPT
}

enum PlayerAuditAction {
  CREATE
  UPDATE
  DEACTIVATE
  REACTIVATE
  MEDICAL_STATUS_CHANGED
  PAYMENT_STATUS_CHANGED
  DELETE
}

// ─────────────────────────────────────────────────────────────────────────
// Phase A · Global SaaS Foundation
// ─────────────────────────────────────────────────────────────────────────

// A Team is a squad inside a Club: Senior, U17, Women, Reserves, Futsal…
// The Club is the tenant root; the Team is the access-control scope under it.
model Team {
  id        String   @id @default(uuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name      String
  shortName String?
  kind      TeamKind @default(SENIOR)
  gender    Gender   @default(MIXED)
  ageMin    Int?
  ageMax    Int?
  color     String? // hex like #16A34A
  emblem    String? // url or data uri
  notes     String?  @db.Text
  isActive  Boolean  @default(true)

  players      Player[]
  memberships  Membership[]
  currentUsers User[]       @relation("UserCurrentTeam")
  matches      Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, name])
  @@index([clubId])
  @@index([kind])
  @@index([isActive])
}

// A Membership is the ONLY thing that grants access to a Club / Team.
// teamId == null  ⇢  club-wide membership (covers every team)
// teamId != null  ⇢  scoped to that single team
model Membership {
  id       String         @id @default(uuid())
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId   String
  club     Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamId   String?
  team     Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role     MembershipRole
  isActive Boolean        @default(true)
  joinedAt DateTime       @default(now())
  leftAt   DateTime?

  audits MembershipAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clubId, teamId, role])
  @@index([userId])
  @@index([clubId])
  @@index([teamId])
  @@index([role])
  @@index([isActive])
}

model MembershipAuditLog {
  id           String                @id @default(uuid())
  membershipId String?
  membership   Membership?           @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  clubId       String
  club         Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actor        User?                 @relation("MembershipAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action       MembershipAuditAction
  before       Json?
  after        Json?
  reason       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime              @default(now())

  @@index([membershipId])
  @@index([clubId])
  @@index([action])
  @@index([createdAt])
}

enum TeamKind {
  SENIOR
  RESERVES
  ACADEMY_U23
  ACADEMY_U21
  ACADEMY_U19
  ACADEMY_U17
  ACADEMY_U15
  ACADEMY_U13
  ACADEMY_U11
  ACADEMY_U9
  ACADEMY_U7
  WOMEN
  WOMEN_U19
  WOMEN_U17
  FUTSAL
  OTHER
}

enum Gender {
  MEN
  WOMEN
  MIXED
}

// Superset of the legacy UserRole, scope-aware and per-Membership.
// Existing User.role stays as legacy whole-club role for back-compat;
// new code reads MembershipRole.
enum MembershipRole {
  CLUB_OWNER
  CLUB_ADMIN
  HEAD_COACH
  ASSISTANT_COACH
  ANALYST
  MEDICAL_STAFF
  PHYSIO
  SCOUT
  FINANCE_MANAGER
  PARENT
  PLAYER
  DEVICE
}

enum MembershipAuditAction {
  GRANT
  REVOKE
  ROLE_CHANGED
  TEAM_CHANGED
  REACTIVATE
  CONTEXT_SWITCH
}

model PlayerAttribute {
  id       String @id @default(uuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  reflexes       Int?
  gkPositioning  Int?
  handling       Int?
  kicking        Int?
  tackling       Int?
  marking        Int?
  heading        Int?
  defPositioning Int?
  interceptions  Int?
  pace           Int?
  shooting       Int?
  passing        Int?
  dribbling      Int?
  crossing       Int?
  strength       Int?
  stamina        Int?
  agility        Int?
  balance        Int?

  recordedAt DateTime @default(now())

  @@index([playerId])
}

model PlayerGpsData {
  id          String  @id @default(uuid())
  playerId    String
  player      Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sessionId   String?
  sessionType String?

  topSpeed     Float
  avgSpeed     Float
  distance     Float
  sprintCount  Int
  heartRateAvg Int
  heartRateMax Int
  playerLoad   Float
  riskScore    Float @default(0)

  recordedAt DateTime @default(now())

  @@index([playerId])
  @@index([recordedAt])
}

model PlayerInjury {
  id             String         @id @default(uuid())
  playerId       String
  player         Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  bodyPart       String
  injuryType     String
  severity       InjurySeverity
  injuredAt      DateTime       @default(now())
  expectedReturn DateTime?
  returnedAt     DateTime?
  notes          String?

  @@index([playerId])
}

model Match {
  id     String @id @default(uuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // ── Phase B: scope by team + live state ──
  teamId          String?
  team            Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  status          MatchStatus    @default(SCHEDULED)
  periodNow       Int? // 1=H1, 2=H2, 3=ET1, 4=ET2, 5=PEN
  liveStartedAt   DateTime?
  liveMinute      Int? // last reported clock minute when LIVE
  formationHome   String? // e.g. "4-3-3"
  formationAway   String?
  opponentNotes   String?        @db.Text
  aiInsights      Json?
  deviceSessionId String?        @unique
  deviceSession   DeviceSession? @relation("MatchDeviceSession", fields: [deviceSessionId], references: [id], onDelete: SetNull)

  homeTeam        String
  awayTeam        String
  homeScore       Int?
  awayScore       Int?
  isHome          Boolean         @default(true)
  competition     CompetitionType @default(LEAGUE)
  competitionName String?
  result          MatchResult?

  venue       String?
  scheduledAt DateTime
  playedAt    DateTime?

  possession    Float?
  shots         Int?
  shotsOnTarget Int?
  corners       Int?
  fouls         Int?
  yellowCards   Int?
  redCards      Int?

  playerStats PlayerMatchStat[]
  season      String?

  // ── Phase B relations ──
  lineups           MatchLineup[]
  timeline          MatchTimeline[]
  tacticalSnapshots MatchTacticalSnapshot[]
  auditLogs         MatchAuditLog[]

  // ── Phase Q relations ──
  events           MatchEvent[]
  fixtures         Fixture[]
  playerMatchStats PlayerMatchStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([teamId])
  @@index([status])
  @@index([scheduledAt])
}

model PlayerMatchStat {
  id       String @id @default(uuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  minutesPlayed Int    @default(0)
  goals         Int    @default(0)
  assists       Int    @default(0)
  shots         Int    @default(0)
  passes        Int    @default(0)
  passAccuracy  Float  @default(0)
  tackles       Int    @default(0)
  rating        Float?

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase B · Match Intelligence System
// ─────────────────────────────────────────────────────────────────────────

// One row per side per match: starters, bench, formation, position grid.
model MatchLineup {
  id        String    @id @default(uuid())
  matchId   String
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  side      MatchSide
  formation String? // "4-3-3", "3-5-2"
  notes     String?   @db.Text
  // Compact position grid for our team:
  //   [{ playerId, position, x, y, isStarter, captainBand, jerseyNumber }, ...]
  // Opponent side: [{ name, position, x, y, isStarter }, ...]
  positions Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([matchId, side])
  @@index([matchId])
}

// Live human-entered events. SEPARATE from VisionAnalysisRun's MatchEvent
// (which is machine-derived from vision). Both join on matchId.
model MatchTimeline {
  id                String            @id @default(uuid())
  matchId           String
  match             Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  occurredAtMin     Int // clock minute (0-130)
  occurredAtSec     Int? // optional sub-minute precision
  period            Int               @default(1)
  kind              MatchTimelineKind
  side              MatchSide
  primaryPlayerId   String? // own player (if scoped to our team)
  secondaryPlayerId String? // for assists / sub-out
  opponentName      String? // free-text for opponent-side events
  pitchX            Float? // 0..100
  pitchY            Float? // 0..100
  notes             String?           @db.Text
  payload           Json? // shot-on-target, card colour, sub direction, etc.
  enteredByUserId   String?
  isDeleted         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([matchId, occurredAtMin])
  @@index([matchId, kind])
  @@index([primaryPlayerId])
}

// Tactical snapshot — frozen state of pitch + formation + notes.
// Taken manually by coach or every N minutes by an automation.
model MatchTacticalSnapshot {
  id           String             @id @default(uuid())
  matchId      String
  match        Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  takenAtMin   Int
  period       Int                @default(1)
  phase        MatchTacticalPhase @default(OPEN_PLAY)
  formation    String? // "4-3-3"
  possession   Float? // 0..100
  // [{ playerId|opponentName, side, x, y, role }, ...]
  positions    Json
  notes        String?            @db.Text
  source       TacticalSource     @default(MANUAL)
  authorUserId String?
  createdAt    DateTime           @default(now())

  @@index([matchId, takenAtMin])
  @@index([matchId, phase])
}

// Audit trail per Match. Reuses the Phase 2 PlayerAuditLog pattern.
model MatchAuditLog {
  id        String           @id @default(uuid())
  matchId   String
  match     Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  clubId    String
  userId    String?
  action    MatchAuditAction
  before    Json?
  after     Json?
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime         @default(now())

  @@index([matchId])
  @@index([clubId])
  @@index([action])
  @@index([createdAt])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FT
  POSTPONED
  ABANDONED
  CANCELLED
}

enum MatchSide {
  HOME
  AWAY
}

enum MatchTimelineKind {
  GOAL
  OWN_GOAL
  ASSIST
  SHOT
  SHOT_ON_TARGET
  SHOT_OFF_TARGET
  SAVE
  YELLOW_CARD
  SECOND_YELLOW
  RED_CARD
  SUBSTITUTION
  INJURY
  FOUL
  CORNER
  OFFSIDE
  PENALTY_AWARDED
  PENALTY_SCORED
  PENALTY_MISSED
  POSSESSION_TICK // periodic sampling
  TACTICAL_NOTE
  AI_INSIGHT
  CUSTOM
}

enum MatchTacticalPhase {
  OPEN_PLAY
  ATTACKING_TRANSITION
  DEFENSIVE_TRANSITION
  ATTACKING_ORGANIZATION
  DEFENSIVE_ORGANIZATION
  SET_PIECE_FOR
  SET_PIECE_AGAINST
}

enum TacticalSource {
  MANUAL
  AUTO_INTERVAL
  AI_AGENT
  VISION
}

enum MatchAuditAction {
  CREATE
  UPDATE
  STATUS_CHANGED
  LINEUP_SET
  TIMELINE_ADDED
  TIMELINE_EDITED
  TIMELINE_DELETED
  SNAPSHOT_TAKEN
  DELETE
}

// ─────────────────────────────────────────────────────────────────────────
// Phase B · Hardware / PCB ecosystem (placeholder data plane)
// ─────────────────────────────────────────────────────────────────────────

// One row per device usage interval. SensorPacket(s) ALWAYS reference a session,
// never the device directly. Tenant lives on the session — never the packet.
model DeviceSession {
  id                String    @id @default(uuid())
  clubId            String
  teamId            String?
  matchId           String?   @unique
  trainingSessionId String?   @unique
  deviceModel       String // FAMILISTA_WEARABLE_V1, FAMILISTA_TURF_NODE_V1, FAMILISTA_AI_CAM_V1
  deviceSerial      String
  edgeFwVersion     String?
  sessionKey        String? // HMAC seed (server-issued at session open; nullable for legacy)
  startedAt         DateTime
  endedAt           DateTime?
  metadata          Json?

  packets SensorPacket[]
  match   Match?         @relation("MatchDeviceSession")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([teamId])
  @@index([deviceModel])
  @@index([deviceSerial])
  @@index([startedAt])
}

// Append-only sensor stream. One row per packet; partition + archive later.
model SensorPacket {
  id              String           @id @default(uuid())
  deviceSessionId String
  deviceSession   DeviceSession    @relation(fields: [deviceSessionId], references: [id], onDelete: Cascade)
  kind            SensorPacketKind
  capturedAt      DateTime
  receivedAt      DateTime         @default(now())
  payload         Json
  sigB64          String? // HMAC(sha256, sessionKey, capturedAt|payload)

  @@index([deviceSessionId, capturedAt])
  @@index([kind])
}

enum SensorPacketKind {
  GPS
  IMU
  ECG
  HEART_RATE
  HEALTH_BUNDLE
  EVENT
  VISION_FRAME
  TURF_NODE
  POWER
  DIAGNOSTIC
}

// ─────────────────────────────────────────────────────────────────────────
// Phase B · Automation + AI Agent framework (data plane only; workers later)
// ─────────────────────────────────────────────────────────────────────────

model AutomationTask {
  id          String            @id @default(uuid())
  clubId      String
  teamId      String?
  kind        AutomationKind
  name        String
  schedule    String? // cron expression OR ISO interval OR null=manual
  isActive    Boolean           @default(true)
  budgetCents Int               @default(0)
  params      Json?
  lastRunAt   DateTime?
  lastStatus  AutomationStatus?
  createdBy   String?

  runs AutomationRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([teamId])
  @@index([kind])
  @@index([isActive])
}

model AutomationRun {
  id         String           @id @default(uuid())
  taskId     String
  task       AutomationTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  status     AutomationStatus @default(PENDING)
  output     Json?
  error      String?          @db.Text
  costCents  Int              @default(0)
  costTokens Int              @default(0)

  @@index([taskId])
  @@index([status])
