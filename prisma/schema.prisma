  @@index([athleteIdHash])
}

/// ContractIntelligenceSnapshot — market-wide contract negotiation signals.
model ContractIntelligenceSnapshot {
  id            String   @id @default(uuid())
  clubId        String?
  athleteIdHash String?
  /// "EXPIRY_SOON" | "RENEWAL_LIKELY" | "BOSMAN_RISK" | "TRANSFER_CANDIDATE"
  signal        String
  payload       Json
  modelVersion  String   @default("n1")
  createdAt     DateTime @default(now())

  @@index([clubId, signal, createdAt])
}

/// AcademyDevelopmentForecast — forward-looking academy ROI projection.
model AcademyDevelopmentForecast {
  id                  String   @id @default(uuid())
  clubId              String
  academyName         String
  horizonYears        Int      @default(5)
  projectedValueCents BigInt   @default(0)
