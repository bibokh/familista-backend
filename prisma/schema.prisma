  modelVersion        String   @default("n1")
  createdAt           DateTime @default(now())

  @@index([clubId, academyName, createdAt])
}

// ── Knowledge reasoning layer ───────────────────────────────────────────

/// ReasoningTrace — every reasoning call leaves a trace. Replay-safe.
model ReasoningTrace {
  id           String        @id @default(uuid())
  clubId       String
  kind         ReasoningKind
  question     String        @db.Text
  /// Ordered list of rule ids + intermediate results.
  steps        Json
  conclusion   Json
  modelVersion String        @default("n1")
  createdAt    DateTime      @default(now())

  @@index([clubId, kind, createdAt])
}

/// ExplainableDecision — the audit-anchored final decision row.
model ExplainableDecision {
  id           String   @id @default(uuid())
  clubId       String
  /// Reference to the ReasoningTrace that produced this decision.
  traceId      String?
  topic        String
  decision     String
  rationale    String   @db.Text
  /// Sources / evidence pointers (e.g. ["GlobalKnowledgeNode:abc", "ScoutingEvaluation:xyz"]).
  sources      Json
  payloadHash  String?
  /// HMAC signature of the canonical decision body.
  signatureB64 String?
  modelVersion String   @default("n1")
  createdAt    DateTime @default(now())

  @@index([clubId, createdAt])
  @@index([traceId])
}

/// DeterministicReasoningRule — rule library used by the reasoner.
/// Append-only versioning; old rules remain queryable for replay.
model DeterministicReasoningRule {
  id          String        @id @default(uuid())
  /// null = global rule.
  clubId      String?
  code        String
  label       String
  kind        ReasoningKind
  /// Rule expression in JSON: { when: [...], then: [...] }
  rule        Json
  version     Int           @default(1)
  isActive    Boolean       @default(true)
  publishedBy String?
  publishedAt DateTime      @default(now())

  @@unique([clubId, code, version])
  @@index([kind, isActive])
}

// ── Security extensions ─────────────────────────────────────────────────

/// CryptographicGraphAnchor — sha256 anchor of a graph snapshot pinned
/// into the Phase I audit chain. Lets replay verify the graph hasn't
/// been tampered with between snapshot and now.
model CryptographicGraphAnchor {
  id          String   @id @default(uuid())
  clubId      String
  /// "KNOWLEDGE_GRAPH" | "RECOMMENDATION_CHAIN" | "TALENT_EVOLUTION"
  anchorKind  String
  /// Sha256 over the canonical snapshot content.
  sha256      String
  /// Number of nodes / rows participating.
  cardinality Int      @default(0)
  asOf        DateTime
  createdAt   DateTime @default(now())

  @@index([clubId, anchorKind, asOf])
  @@index([sha256])
}

/// RecommendationSignature — durable HMAC signature record per signed
/// recommendation. Lets us re-verify a signature offline.
model RecommendationSignature {
  id                 String   @id @default(uuid())
  clubId             String
  /// FK by id-string to GlobalRecommendationRanking or ExplainableDecision.
  recommendationId   String
  recommendationKind String // "GLOBAL_RANKING" | "EXPLAINABLE_DECISION"
  signatureB64       String
  payloadHash        String
  signerVersion      String   @default("n1")
  createdAt          DateTime @default(now())

  @@unique([recommendationId, recommendationKind])
  @@index([clubId, createdAt])
}

/// TrustScore — running trust score per source. Updated on every
/// evaluation outcome with a deterministic rule.
model TrustScore {
  id           String   @id @default(uuid())
  clubId       String?
  sourceKind   String // "SCOUT" | "AGENT" | "DATA_PROVIDER" | "AI_AGENT"
  sourceRef    String
  score        Float    @default(0.5) // 0..1
  observations Int      @default(0)
  components   Json?
  modelVersion String   @default("n1")
  updatedAt    DateTime @updatedAt

  @@unique([clubId, sourceKind, sourceRef])
  @@index([sourceKind])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase O — Production Reality Layer
// ─────────────────────────────────────────────────────────────────────────
// Additive only. No FK back-relations on existing models. Hardens the
// platform for real-world deployment: auth sessions, MFA, club operations,
// player lifecycle, hardware deployment, governance, monitoring, backups.

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MfaMethod {
  NONE
  TOTP
  EMAIL
  BACKUP_CODE
}

enum AttendanceMark {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  INJURED
}

enum OperationsPaymentState {
  PENDING
  PAID
  OVERDUE
  REFUNDED
  CANCELED
}

enum ClubEventKind {
  TRAINING
  MATCH
  MEDICAL
  MEETING
  TRAVEL
  OTHER
}

enum PlayerContractState {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum GdprRequestKind {
  EXPORT
  DELETE
  RECTIFICATION
  PORTABILITY
}

enum GdprRequestState {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum ConsentScope {
  MEDICAL
  MARKETING
  DATA_SHARING
  RESEARCH
  IMAGE_USE
  CUSTOM
}

enum HealthCheckState {
  OK
  DEGRADED
  DOWN
}

enum AlertRuleState {
  ACTIVE
  MUTED
  ARCHIVED
}

enum BackupKind {
  SCHEDULED
  MANUAL
  PRE_DEPLOY
  RESTORE_POINT
}

enum DeviceInventoryState {
  STOCK
  DEPLOYED
  RMA
  RETIRED
}

// ── Auth production ─────────────────────────────────────────────────────

/// AuthSession — refresh token rotation + device fingerprint + revocation.
model AuthSession {
  id              String            @id @default(uuid())
  userId          String
  /// SHA-256 hash of the refresh token (never stored raw).
  refreshHash     String            @unique
  deviceLabel     String?
  ipAddress       String?
  userAgent       String?
  status          AuthSessionStatus @default(ACTIVE)
  /// MFA challenge requirement satisfied at session start.
  mfaSatisfied    Boolean           @default(false)
  createdAt       DateTime          @default(now())
  lastUsedAt      DateTime          @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedReason   String?
  /// Parent session id when this row is a rotated refresh token.
  parentSessionId String?

  @@index([userId, status])
  @@index([expiresAt])
}

/// MFASetting — per-user MFA enrollment state. Secret is stored encrypted
/// (HMAC-derived envelope from jwt.secret).
model MFASetting {
  id              String    @id @default(uuid())
  userId          String    @unique
  method          MfaMethod @default(NONE)
  secretEncrypted String?
  backupCodesHash Json?
  enabledAt       DateTime?
  lastVerifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// MFAChallenge — short-lived one-time challenge for verification.
model MFAChallenge {
  id            String    @id @default(uuid())
  userId        String
  /// SHA-256 of the challenge code; the user provides the plain code.
  challengeHash String
  expiresAt     DateTime
  consumedAt    DateTime?
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([userId, expiresAt])
}

