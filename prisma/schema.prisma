// ─────────────────────────────────────────────────────────────────────────
// Phase K — Autonomous Cognitive Vision + Neuromorphic Sports Intelligence
// ─────────────────────────────────────────────────────────────────────────
// All additive. No FK back-relations on existing models. Anchored to
// Phase G Camera / Phase F Device by id-string only.

enum VisionStreamStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum CameraRigSyncStrategy {
  NTP
  PTP
  EVENT_BEACON
  MANUAL
}

enum CameraRigRole {
  CORNER
  FENCE
  OVERHEAD
  WEARABLE
  PANORAMIC
  AERIAL
  GENERIC
}

enum TacticalSignalKind {
  FORMATION
  PRESSING
  DEFENSIVE_LINE
  OVERLOAD_ZONE
  SPACE_CREATION
  TRANSITION_MOMENT
  COUNTERATTACK
  POSITIONAL_COLLAPSE
}

enum VisionSubjectKind {
  PLAYER
  BALL
  OBJECT
  UNKNOWN
}

enum EdgeVisionRuntimeStatus {
  PROVISIONED
  ACTIVE
  DEGRADED
  OFFLINE
  RETIRED
}

// ── Neuromorphic event streams ──────────────────────────────────────────

/// EventCameraStream — long-lived stream identifier per (camera, match,
/// sessionRef). One row per "let's open the camera for this match"
/// session. Append-only event batches reference streamId.
model EventCameraStream {
  id           String             @id @default(uuid())
  clubId       String
  cameraId     String
  matchId      String?
  sessionRef   String // operator-provided correlation id (e.g. "match-2026-Q1-leg1")
  status       VisionStreamStatus @default(ACTIVE)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  packetsTotal BigInt             @default(0)
  eventsTotal  BigInt             @default(0)
  syncVersion  Int                @default(0)
  metadata     Json?

  @@unique([cameraId, sessionRef])
  @@index([clubId, openedAt])
  @@index([matchId, openedAt])
  @@index([status])
}

/// VisionEventBatch — HIGH-RATE append-only. ONE row per ingest call,
/// carrying up to 5_000 pre-aggregated events. NEVER one row per event —
/// individual events live INSIDE the `events` JSON tuple array.
model VisionEventBatch {
  id          String  @id @default(uuid())
  streamId    String
  clubId      String
  matchId     String?
  /// Server-set on receipt (monotonic across the API instance).
  monotonicMs BigInt
  /// Device frame in microseconds; the camera's clock.
  cameraTsUs  BigInt
  /// "RAW" | "AGGREGATED" | "DOWNSAMPLED" — declared by edge node.
  kind        String  @default("AGGREGATED")
  /// Tuple array [[tMicros, x, y, polarity, extra?], …]. Capped 5_000.
  events      Json
  eventCount  Int     @default(0)
  /// HMAC-SHA256(camera.hmacSecret, cameraTsUs|nonce|sha256(events-json)).
  sigB64      String?
  nonce       String?

  @@index([streamId, monotonicMs])
  @@index([matchId, monotonicMs])
  @@index([clubId, monotonicMs])
}

/// EventPoseEstimate — pose keypoints derived from event clusters.
/// Distinct from Phase J PoseSkeleton because the source is event-based.
model EventPoseEstimate {
  id          String   @id @default(uuid())
  streamId    String
  clubId      String
  matchId     String?
  playerId    String?
  monotonicMs BigInt
  joints      Json
  confidence  Float    @default(0.5)
  createdAt   DateTime @default(now())

  @@index([streamId, monotonicMs])
  @@index([playerId, monotonicMs])
}

/// EventMotionCluster — spatial cluster of events that the edge node
/// determined represent one subject (player / ball burst).
model EventMotionCluster {
  id          String            @id @default(uuid())
  streamId    String
  clubId      String
  matchId     String?
  monotonicMs BigInt
  centroidX   Float
  centroidY   Float
  radius      Float
  density     Float             @default(0)
  /// +1 / -1 / 0 if events were ON/OFF/mixed events.
  polarity    Int               @default(0)
  subjectKind VisionSubjectKind @default(UNKNOWN)
  subjectId   String?
  /// Latency from cameraTsUs to detection (μs).
  latencyUs   BigInt?
  createdAt   DateTime          @default(now())

  @@index([streamId, monotonicMs])
  @@index([subjectKind, subjectId])
}

/// VisionTimestampSync — per-camera clock-skew anchor. Multiple rows per
/// camera over time; the active one is the latest by version per session.
model VisionTimestampSync {
  id         String   @id @default(uuid())
  cameraId   String
  sessionRef String
  /// Camera-local device microseconds at the anchor.
  deviceUs   BigInt
  /// Server epoch ms at the anchor.
  serverRxMs BigInt
  skewMs     Float    @default(0)
  jitterMs   Float?
  version    Int      @default(1)
  isActive   Boolean  @default(true)
  capturedAt DateTime @default(now())

  @@unique([cameraId, sessionRef, version])
  @@index([cameraId, isActive])
}

// ── Multi-camera tactical perception ────────────────────────────────────

/// CameraRig — a logical group of physical Cameras locked together.
model CameraRig {
  id           String                @id @default(uuid())
  clubId       String
  label        String
  syncStrategy CameraRigSyncStrategy @default(NTP)
  /// Pitch geometry (origin + axis) so triangulation can land in pitch metres.
  geometry     Json?
  metadata     Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([clubId])
}

/// CameraRigMember — M:N Camera ↔ CameraRig with assigned role.
model CameraRigMember {
  id       String        @id @default(uuid())
  rigId    String
  cameraId String
  role     CameraRigRole @default(GENERIC)
  position Json? // pitch-anchor metres { x, y, z, azimuth, pitch }
  isActive Boolean       @default(true)
  joinedAt DateTime      @default(now())

  @@unique([rigId, cameraId])
  @@index([cameraId])
}

/// CameraSyncSession — one row per "lock the rig" event.
model CameraSyncSession {
  id         String    @id @default(uuid())
  rigId      String
  matchId    String?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  /// Common monotonic base across the rig (μs).
  anchorTsUs BigInt?
  /// Per-camera skew snapshot { cameraId → skewMs }.
  skews      Json?
  ok         Boolean   @default(true)
  notes      String?

  @@index([rigId, startedAt])
  @@index([matchId, startedAt])
}

/// MultiCameraObservation — fused per-subject observation at one window.
model MultiCameraObservation {
  id                    String            @id @default(uuid())
  syncSessionId         String
  clubId                String
  matchId               String?
  monotonicMs           BigInt
  subjectKind           VisionSubjectKind @default(UNKNOWN)
  subjectId             String? // playerId or "ball"
  contributingCameras   Json // string[]
  /// Reference to the SpatialTriangulationResult (by id-string).
  triangulationResultId String?
  createdAt             DateTime          @default(now())

  @@index([syncSessionId, monotonicMs])
  @@index([matchId, subjectKind])
}

/// SpatialTriangulationResult — 3D consensus point with vote diagnostics.
model SpatialTriangulationResult {
  id            String            @id @default(uuid())
  syncSessionId String
  clubId        String
  matchId       String?
  monotonicMs   BigInt
  subjectKind   VisionSubjectKind @default(UNKNOWN)
  subjectId     String?
  x             Float
  y             Float
  z             Float             @default(0)
  confidence    Float             @default(0.5)
  votes         Int               @default(0)
  residualMeanM Float?
  createdAt     DateTime          @default(now())

  @@index([syncSessionId, monotonicMs])
  @@index([matchId, subjectId])
}

// ── Autonomous visual tactical engine ───────────────────────────────────

/// VisualTacticalSignal — raw signal row produced by the autonomous engine.
model VisualTacticalSignal {
  id              String             @id @default(uuid())
  clubId          String
  matchId         String
  signalKind      TacticalSignalKind
  monotonicMs     BigInt
  /// Side the signal pertains to ('HOME' | 'AWAY' | 'NEUTRAL').
  side            String             @default("NEUTRAL")
  /// 0..1 intensity / confidence.
  intensity       Float              @default(0.5)
  /// Compact JSON the engine produced (positions, vectors, etc.).
  payload         Json
  detectorVersion String             @default("v1")
  createdAt       DateTime           @default(now())

  @@index([matchId, signalKind, monotonicMs])
  @@index([clubId, createdAt])
}

/// TacticalPatternDetection — composite of multiple VisualTacticalSignal
/// rows into a higher-order pattern (e.g. "high-press + overload-right").
model TacticalPatternDetection {
  id                    String   @id @default(uuid())
  clubId                String
  matchId               String
  monotonicMs           BigInt
  patternKind           String // free-text composite tag
  contributingSignalIds Json // string[]
  intensity             Float    @default(0.5)
  rationale             String?  @db.Text
  detectorVersion       String   @default("v1")
  createdAt             DateTime @default(now())

  @@index([matchId, patternKind, monotonicMs])
}

/// VisualFormationState — autonomously detected formation snapshot.
model VisualFormationState {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  side            String   @default("HOME")
  formation       String // "4-3-3" | "5-1" | …
  spotsPayload    Json // [{ role, x, y }, …]
  confidence      Float    @default(0.5)
  detectorVersion String   @default("v1")
  createdAt       DateTime @default(now())

  @@index([matchId, side, monotonicMs])
}

/// PressingIntensityEstimate — derived from event clusters + player density.
model PressingIntensityEstimate {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  side            String   @default("HOME")
  intensity       Float    @default(0) // 0..1
  synchronyIndex  Float? // see neuro-metrics
  pressureMass    Float?
  detectorVersion String   @default("v1")
  createdAt       DateTime @default(now())

  @@index([matchId, side, monotonicMs])
}

/// DefensiveLineEstimate — back-line height + spread + stability.
model DefensiveLineEstimate {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  side            String   @default("HOME")
  lineX           Float
  spreadY         Float
  stabilityIndex  Float    @default(0.5)
  detectorVersion String   @default("v1")
  createdAt       DateTime @default(now())

  @@index([matchId, side, monotonicMs])
}

/// OverloadZoneEstimate — local numerical superiority detection.
model OverloadZoneEstimate {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  /// Cell centroid in pitch metres.
  zoneX           Float
  zoneY           Float
  homeCount       Int      @default(0)
  awayCount       Int      @default(0)
  delta           Int      @default(0)
  intensity       Float    @default(0.5)
  detectorVersion String   @default("v1")
  createdAt       DateTime @default(now())

  @@index([matchId, monotonicMs])
}

// ── Edge AI vision runtime ──────────────────────────────────────────────

/// EdgeVisionRuntime — the vision-AI runtime hosted by a Phase J EdgeNode.
/// Distinct from EdgeNode because a single box can host multiple runtimes
/// (different model bundles).
model EdgeVisionRuntime {
  id         String                  @id @default(uuid())
  clubId     String
  edgeNodeId String?
  cameraId   String?
  label      String
  fwVersion  String?
  os         String?
  hwClass    String? // "JETSON_ORIN" | "RPI5" | "X86_GPU" | …
  status     EdgeVisionRuntimeStatus @default(PROVISIONED)
  lastSeenAt DateTime?
  metadata   Json?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([clubId, status])
  @@index([edgeNodeId])
  @@index([cameraId])
}

/// EdgeModelManifest — catalog of available vision-AI models.
model EdgeModelManifest {
  id          String   @id @default(uuid())
  code        String   @unique // "PLAYER_DETECT_V1" | "POSE_LITE_V2" | …
  label       String
  family      String // "detect" | "pose" | "ball" | "tactical"
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// EdgeModelVersion — versioned binary for one EdgeModelManifest.
model EdgeModelVersion {
  id          String   @id @default(uuid())
  manifestId  String
  version     String // semver
  sha256      String // 64-char hex
  sizeBytes   Int      @default(0)
  downloadUrl String?
  publishedAt DateTime @default(now())
  isActive    Boolean  @default(true)

  @@unique([manifestId, version])
  @@index([manifestId, isActive])
}

/// EdgeVisionInference — per-packet inference result from an edge runtime.
/// Distinct from Phase J EdgeInferenceResult: this row carries an HMAC sig
/// from the runtime and references the model VERSION used.
model EdgeVisionInference {
  id             String   @id @default(uuid())
  runtimeId      String
  clubId         String
  matchId        String?
  cameraId       String?
  modelVersionId String?
  monotonicMs    BigInt
  kind           String // "DETECT" | "POSE" | "BALL" | …
  payload        Json
  confidence     Float    @default(0.5)
  latencyMs      Int?
  sigB64         String?
  nonce          String?
  createdAt      DateTime @default(now())

  @@index([runtimeId, monotonicMs])
  @@index([matchId, kind])
}

/// EdgeVisionHealth — rolling health snapshot per runtime.
model EdgeVisionHealth {
  id             String   @id @default(uuid())
  runtimeId      String
  score          Float    @default(1.0)
  latencyP95Ms   Int?
  jobsPerMin     Float    @default(0)
  failuresPerMin Float    @default(0)
  capturedAt     DateTime @default(now())

  @@index([runtimeId, capturedAt])
}

// ── Biomechanical patches ───────────────────────────────────────────────

/// BiomechanicalPacket — biochem / wearable patch data. Higher-level than
/// SensorPacket so we can preserve patentable fields (lactate, glucose,
/// hydration, cortisol proxy). Anchored to a Phase F Device.
model BiomechanicalPacket {
  id            String   @id @default(uuid())
  clubId        String
  matchId       String?
  playerId      String?
  deviceId      String?
  /// Server epoch ms.
  monotonicMs   BigInt
  /// Device frame ms (patch clock).
  deviceTsMs    BigInt
  lactateMmol   Float?
  glucoseMg     Float?
  hydrationPct  Float?
  cortisolProxy Float?
  /// Raw extra fields (per-device payload).
  payload       Json?
  sigB64        String?
  nonce         String?
  createdAt     DateTime @default(now())

  @@index([playerId, monotonicMs])
  @@index([matchId, monotonicMs])
  @@index([clubId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase L — Federated Cognition + Real Hardware + Simulation + Game Graph
// ─────────────────────────────────────────────────────────────────────────
// All additive. No FK back-relations on existing models.

enum HardwareProvisioningStatus {
  CREATED
  IN_PROGRESS
  ACTIVATED
  SEALED
  FAILED
}

enum FederatedJobStatus {
  PENDING
  RUNNING
  AGGREGATING
  COMPLETED
  FAILED
  CANCELED
}

enum AttestationStatus {
  PENDING
  VERIFIED
  FAILED
  REVOKED
}

enum SimulationStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum CoachRecommendationKind {
  TACTICAL
  INJURY_RISK
  SUBSTITUTION
  TACTICAL_ADAPTATION
  MATCH_ADJUSTMENT
  FORMATION_OPTIMIZATION
  CUSTOM
}

enum GraphSnapshotKind {
  PRESSURE
  PASSING
  THREAT
  INFLUENCE
  CUSTOM
}

// ── 1. Real device abstraction ──────────────────────────────────────────

/// HardwareProvisioningSession — per-device provisioning lifecycle.
/// Lives ABOVE Phase J ProvisioningBatch + DeviceActivation: tracks the
/// step-by-step sequence (cert install, secure-boot enroll, OTA pin).
model HardwareProvisioningSession {
  id          String                     @id @default(uuid())
  clubId      String
  batchId     String?
  deviceId    String?
  serial      String
  status      HardwareProvisioningStatus @default(CREATED)
  /// Ordered checkpoint markers: [{ name, at, ok, payload? }, …]
  steps       Json
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([clubId, status])
  @@index([deviceId])
  @@index([serial])
}

/// DeviceCapabilityProfile — what the hardware CAN do (sensors, AI,
/// network). Catalogued per device model & revision.
model DeviceCapabilityProfile {
  id           String   @id @default(uuid())
  model        String
  hwRevision   String?
  /// Capabilities as JSON for forward-compat:
  ///   { cpuClass, memMB, hasGPU, hasNPU, networks, sensors, edgeAI }
  capabilities Json
  isActive     Boolean  @default(true)
  publishedBy  String?
  publishedAt  DateTime @default(now())

  @@unique([model, hwRevision])
  @@index([model, isActive])
}

/// DeviceSensorMatrix — per-device wiring of which sensors are present +
/// calibrated. Differs from CameraCalibration (Phase G) in that it covers
/// ALL sensors (GPS / IMU / ECG / biochem / vision).
model DeviceSensorMatrix {
  id          String   @id @default(uuid())
  deviceId    String
  /// Matrix shape: [{ sensorKind, slot, calibratedAt, version, ok }, …]
  matrix      Json
  publishedBy String?
  publishedAt DateTime @default(now())
  isActive    Boolean  @default(true)

  @@index([deviceId, isActive])
}

/// DeviceClockDiscipline — strategy + last-known skew per device. Lets us
/// trust packets even when devices vary in their time source (PTP/NTP/
/// VisionTimestampSync).
model DeviceClockDiscipline {
  id         String   @id @default(uuid())
  deviceId   String
  strategy   String // "NTP" | "PTP" | "VISION_SYNC" | "EVENT_BEACON" | "MANUAL"
  lastSkewMs Float?
  jitterMs   Float?
  source     String? // hostname / cameraId / etc.
  capturedAt DateTime @default(now())

  @@index([deviceId, capturedAt])
}

/// DeviceTrustAnchor — cryptographic identity anchor. Pairs the device's
/// hardware-bound certificate + secure-boot fingerprint. Append-only.
model DeviceTrustAnchor {
  id                    String            @id @default(uuid())
  deviceId              String
  /// Public-key fingerprint (sha256 hex).
  certFingerprint       String
  /// Secure-boot ROM hash reported on attestation.
  secureBootHash        String?
  hwSerial              String?
  issuer                String?
  validFrom             DateTime          @default(now())
  validUntil            DateTime?
  revokedAt             DateTime?
  /// Last attestation outcome — denormalised for fast revocation checks.
  lastAttestationStatus AttestationStatus @default(PENDING)

  @@unique([deviceId, certFingerprint])
  @@index([deviceId])
}

/// DeviceAttestation — per-boot attestation record. The device proves it
/// is running unmodified firmware + still has its trust anchor.
model DeviceAttestation {
  id             String            @id @default(uuid())
  deviceId       String
  trustAnchorId  String?
  fwVersion      String?
  secureBootHash String?
  /// Nonce returned by the device, signed with its hmacSecret.
  nonce          String
  sigB64         String
  status         AttestationStatus @default(PENDING)
  reason         String?
  capturedAt     DateTime          @default(now())

  @@index([deviceId, capturedAt])
  @@index([status])
}

// ── 2. Federated sports intelligence ────────────────────────────────────

/// FederatedTrainingJob — one row per (sport, model family, round).
model FederatedTrainingJob {
  id                String             @id @default(uuid())
  /// Optional initiator club (null = platform-initiated round).
  initiatorClubId   String?
  sport             SportKind          @default(FOOTBALL)
  modelFamily       String // "tactical_press_v1" | "injury_risk_v2" | …
  roundNumber       Int                @default(0)
  /// Deterministic seed so aggregation is replayable.
  aggregationSeed   BigInt
  /// Privacy boundary applied to this round.
  privacyBoundaryId String?
  /// Clipping norm + dp epsilon for safety bounds.
  clippingNormMax   Float?
  status            FederatedJobStatus @default(PENDING)
  startedAt         DateTime?
  closedAt          DateTime?
  metadata          Json?
  createdAt         DateTime           @default(now())

  @@index([modelFamily, roundNumber])
  @@index([status, sport])
}

/// FederatedGradientEnvelope — one club's submission for a round.
model FederatedGradientEnvelope {
  id             String    @id @default(uuid())
  jobId          String
  clubId         String
  /// SHA-256 of the gradient payload (we don't store the raw tensor).
  payloadHash    String
  /// Optional encrypted blob (downstream-managed; we just keep the ref).
  blobRef        String?
  /// Anti-replay nonce.
  nonce          String
  sigB64         String?
  /// Norm of the submission (post-clip).
  normValue      Float?
  acceptedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime  @default(now())

  @@unique([jobId, clubId, nonce])
  @@index([jobId])
  @@index([clubId, createdAt])
}

/// FederatedModelCheckpoint — aggregated checkpoint emitted by the round.
model FederatedModelCheckpoint {
  id               String   @id @default(uuid())
  jobId            String
  version          String
  payloadHash      String // sha256 of the aggregated model
  blobRef          String?
  participants     Int      @default(0)
  /// Deterministic order in which gradients were folded — JSON club ids.
  participantOrder Json
  publishedAt      DateTime @default(now())

  @@unique([jobId, version])
  @@index([jobId])
}

/// ClubModelPartition — which slice of which model belongs to which club.
/// Lets us scope privacy: a club's data only flows into partitions it owns.
model ClubModelPartition {
  id           String   @id @default(uuid())
  clubId       String
  modelFamily  String
  partitionKey String // arbitrary tag (e.g. "EU/U21/possession")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([clubId, modelFamily, partitionKey])
  @@index([modelFamily, active])
}

/// PrivacyBoundary — DP epsilon, k-anonymity, aggregation-only flags.
model PrivacyBoundary {
  id              String   @id @default(uuid())
  modelFamily     String
  /// Differential-privacy epsilon (lower = stronger).
  dpEpsilon       Float    @default(1.0)
  /// k-anonymity floor.
  kAnonymity      Int      @default(5)
  aggregationOnly Boolean  @default(true)
  notes           String?
  publishedAt     DateTime @default(now())
  isActive        Boolean  @default(true)

  @@unique([modelFamily])
  @@index([modelFamily, isActive])
}

/// AggregatedSportsModel — versioned global model output, read-only to clubs.
model AggregatedSportsModel {
  id          String   @id @default(uuid())
  modelFamily String
  version     String
  sha256      String
  downloadUrl String?
  publishedAt DateTime @default(now())
  isActive    Boolean  @default(true)

  @@unique([modelFamily, version])
  @@index([modelFamily, isActive])
}

/// FederatedTrustBoundary — which clubs may participate in which family.
model FederatedTrustBoundary {
  id          String   @id @default(uuid())
  modelFamily String
  clubId      String
  trusted     Boolean  @default(true)
  reason      String?
  publishedAt DateTime @default(now())

  @@unique([modelFamily, clubId])
  @@index([modelFamily, trusted])
}

// ── 3. Autonomous coaching agents ───────────────────────────────────────

/// CoachAgent — a configured coaching persona. One row per (club, persona).
model CoachAgent {
  id        String   @id @default(uuid())
  clubId    String
  label     String
  agentKind AIAgent
  config    Json? // weights, thresholds, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId, isActive])
}

/// CoachRecommendation — unified table for all coaching outputs. The
/// `kind` enum carries the specific recommendation type the user asked
/// for (Tactical / InjuryRisk / Substitution / TacticalAdaptation /
/// MatchAdjustment / FormationOptimization / Custom).
model CoachRecommendation {
  id                String                  @id @default(uuid())
  clubId            String
  matchId           String?
  teamId            String?
  playerId          String?
  agentId           String?
  kind              CoachRecommendationKind
  title             String                  @default("")
  rationale         String                  @db.Text
  /// Compact payload the panel renders.
  payload           Json
  confidence        Float                   @default(0.5)
  tacticalImpact    AIDecisionImpact        @default(LOW)
  /// Optional Phase I approval gate link.
  approvalRequestId String?
  /// Hash of the canonical payload — anchor for audit chain.
  payloadHash       String?
  detectorVersion   String                  @default("l1")
  status            AlertStatus             @default(OPEN)
  createdAt         DateTime                @default(now())
  ackedAt           DateTime?
  ackedBy           String?

  @@index([clubId, kind, createdAt])
  @@index([matchId, kind])
  @@index([playerId, kind])
}

// ── 4. Digital twin simulation engine ───────────────────────────────────

/// TwinSimulationSession — one row per "let's simulate alternate history".
model TwinSimulationSession {
  id            String           @id @default(uuid())
  clubId        String
  matchId       String?
  label         String
  /// Deterministic seed for branching.
  seed          BigInt
  status        SimulationStatus @default(DRAFT)
  /// Reference to the source SpatialFrame the sim branched from.
  sourceFrameId String?
  rootBranchId  String?
  createdById   String?
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime         @default(now())

  @@index([clubId, status])
  @@index([matchId, status])
}

/// MatchSimulationState — snapshot of the simulated game at a tick.
model MatchSimulationState {
  id        String   @id @default(uuid())
  sessionId String
  branchId  String?
  /// Sim-clock tick (ms since branch start).
  tickMs    BigInt
  /// Compact spatial + score + possession snapshot.
  state     Json
  createdAt DateTime @default(now())

  @@index([sessionId, tickMs])
  @@index([branchId, tickMs])
}

/// TacticalBranch — node in the simulation branching tree.
model TacticalBranch {
  id                String   @id @default(uuid())
  sessionId         String
  parentBranchId    String?
  label             String
  /// What changed at the divergence point.
  divergencePayload Json
  createdAt         DateTime @default(now())

  @@index([sessionId])
  @@index([parentBranchId])
}

/// PredictedPossessionFlow — derived per-branch possession over time.
model PredictedPossessionFlow {
  id        String   @id @default(uuid())
  sessionId String
  branchId  String
  /// [{ tickMs, ourPct, awayPct, lastSide }, …]
  series    Json
  createdAt DateTime @default(now())

  @@index([sessionId, branchId])
}

/// PredictedFatigueCurve — per-player projected fatigue over time.
model PredictedFatigueCurve {
  id        String   @id @default(uuid())
  sessionId String
  branchId  String
  playerId  String
  /// [{ tickMs, fatigue, sprint, hr }, …]
  series    Json
  createdAt DateTime @default(now())

  @@index([sessionId, branchId])
  @@index([playerId])
}

/// CounterfactualScenario — a named what-if (e.g. "what if we sub Salah at 60'").
model CounterfactualScenario {
  id          String   @id @default(uuid())
  sessionId   String
  branchId    String?
  label       String
  description String?  @db.Text
  outcome     Json?
  createdAt   DateTime @default(now())

  @@index([sessionId])
}

// ── 5. Realtime cognitive game graph ────────────────────────────────────

/// GameGraph — per-match per-timestamp graph snapshot. nodes + edges as JSON
/// keeps cardinality bounded; specialised graphs below for fast reads.
model GameGraph {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  /// [{ id, kind, ref, x, y, weight }, …]
  nodes           Json
  /// [{ from, to, kind, weight }, …]
  edges           Json
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([matchId, monotonicMs])
}

/// SpatialPressureGraph — pressure diffusion field.
model SpatialPressureGraph {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  /// 2D grid + per-cell pressure value.
  field           Json
  windowMs        Int      @default(5000)
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([matchId, monotonicMs])
}

/// PassingNetworkGraph — passing network from timeline + spatial state.
model PassingNetworkGraph {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  /// { nodes: [{ playerId, weight }], edges: [{ from, to, count }] }
  network         Json
  windowMs        Int      @default(300000)
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([matchId, monotonicMs])
}

/// DynamicThreatMap — opp threat magnitude over the field.
model DynamicThreatMap {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  monotonicMs     BigInt
  /// 2D threat field [{ x, y, threat }, …]
  field           Json
  windowMs        Int      @default(60000)
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([matchId, monotonicMs])
}

/// CognitiveInfluenceScore — per-player influence in a snapshot.
model CognitiveInfluenceScore {
  id              String   @id @default(uuid())
  clubId          String
  matchId         String
  playerId        String
  monotonicMs     BigInt
  score           Float    @default(0)
  components      Json?
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([matchId, monotonicMs])
  @@index([playerId, monotonicMs])
}

// ── 6. Biomechanical + biochemical expansion ────────────────────────────

/// BiochemicalSignal — generic biochem signal (one row per (player, kind)).
model BiochemicalSignal {
  id              String   @id @default(uuid())
  clubId          String
  playerId        String?
  matchId         String?
  kind            String // "SWEAT" | "GLUCOSE" | "LACTATE" | "CORTISOL" | …
  value           Float
  unit            String? // "mmol/L" | "mg/dL" | …
  monotonicMs     BigInt
  sourceDeviceId  String?
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([playerId, kind, monotonicMs])
  @@index([matchId, kind])
}

/// HydrationEstimate — per-player hydration trend.
model HydrationEstimate {
  id              String   @id @default(uuid())
  clubId          String
  playerId        String
  matchId         String?
  monotonicMs     BigInt
  estimatePct     Float    @default(100)
  components      Json?
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([playerId, monotonicMs])
}

/// StressIndex — cortisol + HRV-driven composite stress score.
model StressIndex {
  id              String   @id @default(uuid())
  clubId          String
  playerId        String
  matchId         String?
  monotonicMs     BigInt
  index           Float    @default(0)
  components      Json?
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([playerId, monotonicMs])
}

/// NeuromuscularLoad — IMU-derived muscular load estimate.
model NeuromuscularLoad {
  id              String   @id @default(uuid())
  clubId          String
  playerId        String
  matchId         String?
  monotonicMs     BigInt
  load            Float    @default(0)
  asymmetry       Float?
  components      Json?
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([playerId, monotonicMs])
}

/// TendonRiskEstimate — composite tendon-strain risk.
model TendonRiskEstimate {
  id              String   @id @default(uuid())
  clubId          String
  playerId        String
  matchId         String?
  monotonicMs     BigInt
  risk            Float    @default(0)
  region          String? // "ACHILLES" | "HAMSTRING" | "ADDUCTOR" | …
  components      Json?
  detectorVersion String   @default("l1")
  createdAt       DateTime @default(now())

  @@index([playerId, monotonicMs])
  @@index([region])
}

// ── 7. Global sports abstraction (catalog-level) ────────────────────────

/// SportPlugin — admin-registerable sport extension. The Phase G adapter
/// (in code) is the immutable core; these rows extend it at runtime.
model SportPlugin {
  id          String    @id @default(uuid())
  sport       SportKind
  code        String // "football_5aside" | "tennis_doubles" | …
  label       String
  isActive    Boolean   @default(true)
  publishedBy String?
  publishedAt DateTime  @default(now())

  @@unique([sport, code])
  @@index([sport, isActive])
}

/// TacticalDomain — domain ontology (e.g. "press / counter / set-piece").
model TacticalDomain {
  id          String    @id @default(uuid())
  sport       SportKind
  code        String
  label       String
  parentCode  String? // tree-like ontology
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())

  @@unique([sport, code])
}

/// SportFieldGeometry — overrides Phase G geometry per (sport, plugin).
model SportFieldGeometry {
  id          String    @id @default(uuid())
  sport       SportKind
  pluginCode  String?
  widthM      Float
  heightM     Float
  zones       Json?
  targets     Json?
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())

  @@unique([sport, pluginCode])
}

/// SportEventTaxonomy — catalog of event kinds per sport.
model SportEventTaxonomy {
  id          String    @id @default(uuid())
  sport       SportKind
  eventKind   String // "GOAL" | "ACE" | "TURNOVER" | …
  polarity    String // "OFFENSE" | "DEFENSE" | "NEUTRAL"
  scoreDelta  Int       @default(0)
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())

  @@unique([sport, eventKind])
}

/// SportSpatialRules — per-sport spatial constraints (offside lines, etc.).
model SportSpatialRules {
  id          String    @id @default(uuid())
  sport       SportKind
  pluginCode  String?
  rules       Json
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())

  @@unique([sport, pluginCode])
}

// ── 11. Observability extensions ────────────────────────────────────────

/// RegionalHealthSnapshot — rolling per-region snapshot blob.
model RegionalHealthSnapshot {
  id         String   @id @default(uuid())
  regionId   String
  snapshot   Json
  capturedAt DateTime @default(now())

  @@index([regionId, capturedAt])
}

/// DeviceFleetHealth — fleet-wide aggregate (per (clubId, model)).
model DeviceFleetHealth {
  id            String   @id @default(uuid())
  clubId        String?
  model         String
  totalDevices  Int      @default(0)
  activeDevices Int      @default(0)
  staleDevices  Int      @default(0)
  meanScore     Float    @default(1.0)
  capturedAt    DateTime @default(now())

  @@index([clubId, capturedAt])
  @@index([model, capturedAt])
}

/// AIConsensusHealth — agreement rate across deterministic + LLM paths.
model AIConsensusHealth {
  id              String   @id @default(uuid())
  matchId         String?
  agreementRate   Float    @default(1)
  divergenceCount Int      @default(0)
  windowMs        Int      @default(300000)
  capturedAt      DateTime @default(now())

  @@index([matchId, capturedAt])
}

/// FederatedAggregationHealth — per-round health.
model FederatedAggregationHealth {
  id            String   @id @default(uuid())
  jobId         String
  participants  Int      @default(0)
  rejectedCount Int      @default(0)
  acceptedCount Int      @default(0)
  meanNorm      Float?
  capturedAt    DateTime @default(now())

  @@index([jobId])
}

/// SimulationQueueHealth — twin simulation throughput.
model SimulationQueueHealth {
  id          String   @id @default(uuid())
  pending     Int      @default(0)
  running     Int      @default(0)
  completed1h Int      @default(0)
  failed1h    Int      @default(0)
  capturedAt  DateTime @default(now())

  @@index([capturedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase M — Autonomous Sports Ecosystem
