# Familista — Production .env template
# Copy values into Render dashboard. Never commit real secrets to git.
# Secrets are marked SECRET — keep them in Render's encrypted env, not in code.

# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
API_VERSION=v1
DATABASE_URL=                                          # SECRET, provided by Render Postgres link

# ─── Auth / JWT ──────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                                     # SECRET, openssl rand -hex 48
JWT_REFRESH_SECRET=                                    # SECRET, openssl rand -hex 48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=familista

# ─── Rate limit ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_…                            # SECRET
STRIPE_WEBHOOK_SECRET=whsec_…                          # SECRET

# ─── Mail ────────────────────────────────────────────────────────────────
MAIL_DEFAULT_FROM=no-reply@familista.app

# ─── AI Decision Engine (optional — engine degrades to deterministic-only) ─
ANTHROPIC_API_KEY=sk-ant-…                             # SECRET, optional
AI_LLM_MODEL=claude-sonnet-4-20250514
AI_LLM_MAX_TOKENS=1024
AI_LLM_TIMEOUT_MS=20000

# ─── White-label asset storage ───────────────────────────────────────────
# LOCAL (default) requires a Render persistent disk; mount it at WL_ASSETS_DIR.
# Switch to S3 (or any S3-compatible: R2/B2/Spaces) for multi-instance.
WL_ASSETS_BACKEND=LOCAL
WL_ASSETS_DIR=/var/data/uploads
WL_ASSETS_PUBLIC_PREFIX=/uploads
WL_ASSETS_PUBLIC_BASE_URL=                             # optional, CDN base
WL_ASSETS_S3_BUCKET=                                   # S3 only
WL_ASSETS_S3_REGION=eu-central-1
WL_ASSETS_S3_ENDPOINT=                                 # R2/B2/Spaces only
WL_ASSETS_S3_ACCESS_KEY_ID=                            # SECRET (S3 only)
WL_ASSETS_S3_SECRET_ACCESS_KEY=                        # SECRET (S3 only)
WL_ASSETS_S3_FORCE_PATH_STYLE=false

# ─── Franchise revenue payouts ───────────────────────────────────────────
# LEDGER_ONLY records distributions as paid internally.
# STRIPE_CONNECT pushes money to mapped Stripe Connect accounts.
WL_PAYOUT_BACKEND=LEDGER_ONLY

# ─── Vision Intelligence ─────────────────────────────────────────────────
VISION_INFERENCE_BACKEND=STUB                          # STUB | INTERNAL_WORKER | STATS_PERFORM | HUDL
VISION_WORKER_URL=                                     # required if backend=INTERNAL_WORKER
VISION_WORKER_CALLBACK_URL=                            # https://your-host/api/v1/vision/webhooks/inference
VISION_WORKER_TOKEN=                                   # SECRET, outbound auth to worker
VISION_WEBHOOK_TOKEN=                                  # SECRET, inbound webhook auth

VISION_CLIP_BACKEND=STUB                               # STUB | FFMPEG_WORKER | AWS_MEDIA_CONVERT | MUX
VISION_CLIP_WORKER_URL=
VISION_CLIP_WORKER_CALLBACK_URL=
VISION_CLIP_WORKER_TOKEN=                              # SECRET
VISION_CLIP_WEBHOOK_TOKEN=                             # SECRET

VISION_FUSION_DISTANCE_WEIGHT=0.5
VISION_FUSION_TOPSPEED_WEIGHT=0.3

# ─── Phase O: backup encryption ──────────────────────────────────────────
BACKUP_ENCRYPT_PASS=                                   # SECRET, used by scripts/backup.sh + restore.sh

# ─── Phase P: FC Familista seed (set temporarily for first-time seed only) ─
# Unset FC_FAMILISTA_SEED_CONFIRM immediately after the seed run completes.
FC_FAMILISTA_ADMIN_EMAIL=admin@fcfamilista.local
FC_FAMILISTA_ADMIN_PASSWORD=                           # SECRET, ≥ 12 chars
FC_FAMILISTA_DEFAULT_PASSWORD=                         # SECRET, ≥ 12 chars, for coaches/parents/players
FC_FAMILISTA_SEED_CONFIRM=                             # set to "yes" only when intentionally seeding

# ─── Phase Q: Video storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO) ─
# R2 example endpoint: https://<account-id>.r2.cloudflarestorage.com
VIDEO_S3_REGION=auto
VIDEO_S3_ENDPOINT=                                     # leave blank for AWS S3; required for R2/MinIO
VIDEO_S3_ACCESS_KEY_ID=                                # SECRET
VIDEO_S3_SECRET_ACCESS_KEY=                            # SECRET
VIDEO_BUCKET=familista-video
VIDEO_CDN_BASE_URL=                                    # e.g. https://video.familista.app — set for CDN delivery, leave blank to use presigned S3 GET URLs

# ─── Phase Q: Stats aggregator worker ────────────────────────────────────────
STATS_WORKER_INTERVAL_MS=5000                          # poll interval; default 5000 ms
STATS_WORKER_BATCH=20                                  # outbox events processed per tick
